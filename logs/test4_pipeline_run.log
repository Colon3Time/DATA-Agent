import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Handle .md input — find CSV in parent
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/dana_output.csv')) + sorted(parent.glob('**/*_output.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f"[STATUS] Resolved .md input → CSV: {INPUT_PATH}")

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Identify key columns
target_cols = [c for c in df.columns if any(k in c.lower() for k in ['attrit', 'leave', 'quit', 'churn', 'target', 'label'])]
dept_cols = [c for c in df.columns if any(k in c.lower() for k in ['dept', 'department', 'team'])]
perf_cols = [c for c in df.columns if any(k in c.lower() for k in ['perform', 'rating', 'score', 'efficien'])]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Department columns: {dept_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str', 'category']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id', 'employee', 'name_emp']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN — only numeric columns
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

# Drop columns with zero variance
feature_data = feature_data.loc[:, feature_data.nunique() > 1]
numeric_cols = feature_data.columns.tolist()

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr_matrix = feature_data.corr()
corr_file = os.path.join(OUTPUT_DIR, 'correlation_matrix.csv')
corr_matrix.to_csv(corr_file)
print(f"[STATUS] Saved correlation matrix: {corr_file}")

# Find top correlated pairs
corr_pairs = []
for i in range(len(corr_matrix.columns)):
    for j in range(i+1, len(corr_matrix.columns)):
        val = corr_matrix.iloc[i, j]
        if abs(val) > 0.5:
            corr_pairs.append({
                'col1': corr_matrix.columns[i],
                'col2': corr_matrix.columns[j],
                'correlation': round(val, 3)
            })

corr_pairs.sort(key=lambda x: abs(x['correlation']), reverse=True)
print(f"[STATUS] Found {len(corr_pairs)} strong correlation pairs")

# Plot correlation heatmap
plt.figure(figsize=(14, 10))
sns.heatmap(corr_matrix, annot=False, cmap='RdBu_r', center=0, linewidths=0.5)
plt.title('Feature Correlation Matrix', fontsize=16, fontweight='bold')
plt.tight_layout()
heatmap_file = os.path.join(OUTPUT_DIR, 'correlation_heatmap.png')
plt.savefig(heatmap_file, dpi=150)
plt.close()
print(f"[STATUS] Saved heatmap: {heatmap_file}")

# Correlation with target (if exists)
target_corr = []
if target_cols:
    target = target_cols[0]
    if target in df_encoded.columns:
        for col in feature_cols:
            if col != target and col in df_encoded.columns:
                val = df_encoded[col].corr(df_encoded[target])
                if abs(val) > 0.1:
                    target_corr.append({'feature': col, 'corr_with_target': round(val, 3)})
        target_corr.sort(key=lambda x: abs(x['corr_with_target']), reverse=True)
        print(f"[STATUS] Top correlations with target: {target_corr[:5]}")

# ============================================================
# 3. CLUSTERING ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Standardize features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
inertias = []
K_range = range(2, 11)
silhouette_scores = []
db_scores = []

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    km.fit(X_scaled)
    inertias.append(km.inertia_)
    sil = silhouette_score(X_scaled, km.labels_)
    db = davies_bouldin_score(X_scaled, km.labels_)
    silhouette_scores.append(sil)
    db_scores.append(db)
    print(f"[STATUS] k={k}: inertia={km.inertia_:.2f}, silhouette={sil:.4f}, db={db:.4f}")

# Plot Elbow
plt.figure(figsize=(12, 4))
plt.subplot(1, 2, 1)
plt.plot(K_range, inertias, 'bo-', linewidth=2, markersize=8)
plt.xlabel('Number of clusters (k)', fontsize=12)
plt.ylabel('Inertia', fontsize=12)
plt.title('Elbow Method', fontsize=14, fontweight='bold')
plt.grid(alpha=0.3)

plt.subplot(1, 2, 2)
plt.plot(K_range, silhouette_scores, 'ro-', linewidth=2, markersize=8)
plt.xlabel('Number of clusters (k)', fontsize=12)
plt.ylabel('Silhouette Score', fontsize=12)
plt.title('Silhouette Score by k', fontsize=14, fontweight='bold')
plt.grid(alpha=0.3)

plt.tight_layout()
elbow_file = os.path.join(OUTPUT_DIR, 'elbow_plot.png')
plt.savefig(elbow_file, dpi=150)
plt.close()
print(f"[STATUS] Saved elbow plot: {elbow_file}")

# Find best k
best_k = K_range[np.argmax(silhouette_scores)]
print(f"[STATUS] Best k from silhouette score: {best_k}")

# Final clustering with best k
kmeans = KMeans(n_clusters=best_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df['Cluster'] = cluster_labels
df_encoded['Cluster'] = cluster_labels

# Cluster profiles
cluster_profiles = df_encoded.groupby('Cluster')[numeric_cols].mean()
profile_file = os.path.join(OUTPUT_DIR, 'cluster_profiles.csv')
cluster_profiles.to_csv(profile_file)
print(f"[STATUS] Saved cluster profiles: {profile_file}")

# Add target distribution by cluster if target exists
if target_cols and target_cols[0] in df_encoded.columns:
    target_dist = df_encoded.groupby('Cluster')[target_cols[0]].agg(['mean', 'std', 'count'])
    print(f"[STATUS] Target distribution by cluster:\n{target_dist}")

# ============================================================
# 4. PCA & VISUALIZATION
# ============================================================
print("\n[STATUS] ---- PHASE 4: PCA Visualization ----")

pca = PCA(n_components=min(3, X_scaled.shape[1]))
X_pca = pca.fit_transform(X_scaled)
explained_var = pca.explained_variance_ratio_
print(f"[STATUS] PCA explained variance: {explained_var.sum():.4f}")

# 2D plot
plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='Set2', alpha=0.7, s=50)
plt.xlabel(f'PC1 ({explained_var[0]:.1%} var)', fontsize=12)
plt.ylabel(f'PC2 ({explained_var[1]:.1%} var)', fontsize=12)
plt.title(f'K-Means Clustering (k={best_k}) — PCA Projection', fontsize=14, fontweight='bold')
plt.colorbar(scatter, label='Cluster')
plt.grid(alpha=0.3)
plt.tight_layout()
pca_file = os.path.join(OUTPUT_DIR, 'pca_clusters.png')
plt.savefig(pca_file, dpi=150)
plt.close()
print(f"[STATUS] Saved PCA plot: {pca_file}")

# ============================================================
# 5. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 5: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42)
anomaly_labels = iso_forest.fit_predict(X_scaled)
df['Anomaly'] = anomaly_labels
df_encoded['Anomaly'] = anomaly_labels

n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({n_anomalies/len(df)*100:.1f}%)")

# Analyze anomalies
anomaly_df = df_encoded[df_encoded['Anomaly'] == -1]
normal_df = df_encoded[df_encoded['Anomaly'] == 1]

print(f"[STATUS] Anomaly vs Normal comparison:")
for col in numeric_cols[:10]:  # Limit to first 10 cols to avoid errors
    if col in anomaly_df.columns and col in normal_df.columns:
        # Check if column has any numeric data
        anom_vals = anomaly_df[col].dropna()
        norm_vals = normal_df[col].dropna()
        if len(anom_vals) > 0 and len(norm_vals) > 0:
            anom_mean = anom_vals.mean()
            norm_mean = norm_vals.mean()
            diff_pct = ((anom_mean - norm_mean) / norm_mean * 100) if norm_mean != 0 else 0
            print(f"  {col}: Anomaly={anom_mean:.2f}, Normal={norm_mean:.2f}, Diff={diff_pct:+.1f}%")

# ============================================================
# 6. ASSOCIATION PATTERNS (for categorical data)
# ============================================================
print("\n[STATUS] ---- PHASE 6: Association Pattern Mining ----")

assoc_patterns = []
# Use top features (excluding cluster and anomaly)
top_features = [c for c in numeric_cols[:6]]  # limit to 6 features for readability
binned_data = feature_data[top_features].copy()

for col in top_features:
    try:
        q1, q2, q3 = binned_data[col].quantile([0.25, 0.5, 0.75])
        binned_data[col + '_cat'] = pd.cut(binned_data[col], 
                                           bins=[-np.inf, q1, q2, q3, np.inf],
                                           labels=['Low', 'Mid-Low', 'Mid-High', 'High'])
    except Exception as e:
        print(f"  [WARN] Could not bin column {col}: {e}")

# Find patterns: pairs of categories that co-occur
cat_cols = [c for c in binned_data.columns if c.endswith('_cat')]
for i in range(len(cat_cols)):
    col1 = cat_cols[i]
    col1_base = col1.replace('_cat', '')
    for j in range(i+1, len(cat_cols)):
        col2 = cat_cols[j]
        col2_base = col2.replace('_cat', '')
        try:
            cross = pd.crosstab(binned_data[col1], binned_data[col2], normalize='index')
            for idx1 in cross.index:
                for idx2 in cross.columns:
                    prob = cross.loc[idx1, idx2]
                    if prob > 0.3:  # threshold for interesting patterns
                        assoc_patterns.append({
                            'if': f'{col1_base}_{idx1}',
                            'then': f'{col2_base}_{idx2}',
                            'confidence': round(prob, 3)
                        })
        except Exception as e:
            continue

assoc_patterns.sort(key=lambda x: x['confidence'], reverse=True)
print(f"[STATUS] Found {len(assoc_patterns)} association patterns (confidence>0.3)")

# ============================================================
# 7. GENERATE REPORTS
# ============================================================
print("\n[STATUS] ---- PHASE 7: Generating Reports ----")

# Top features from PCA (most important for variance)
pca_components = pd.DataFrame(
    pca.components_.T,
    columns=[f'PC{i+1}' for i in range(pca.components_.shape[0])],
    index=numeric_cols[:pca.components_.shape[0]]
)
top_features_pca = list(pca_components.abs().sum(axis=1).sort_values(ascending=False).head(5).index)

# Save encoded dataframe
encoded_file = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(encoded_file, index=False)
print(f"[STATUS] Saved output: {encoded_file}")

# ---- mining_results.md ----
mining_report = f"""Max Data Mining Report
======================
Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}

Data Shape: {df.shape[0]} rows, {df.shape[1]} columns
Target Columns: {target_cols}
Features Used: {list(feature_data.columns)}

---

## Techniques Used
1. **Correlation Analysis** — Pearson correlation on all feature pairs
2. **K-Means Clustering** — with Elbow Method + Silhouette Score optimization
3. **PCA Visualization** — 2D projection of clusters
4. **Anomaly Detection** — Isolation Forest (5% contamination)
5. **Association Pattern Mining** — Co-occurrence analysis on binned features

---

## Correlation Analysis
Strongest correlations found:
"""
for cp in corr_pairs[:10]:
    mining_report += f"- **{cp['col1']}** ↔ **{cp['col2']}**: r = {cp['correlation']}\n"

if target_corr:
    mining_report += f"""
Top features correlated with target ({target_cols[0] if target_cols else 'N/A'}):
"""
    for tc in target_corr[:5]:
        mining_report += f"- **{tc['feature']}**: {tc['corr_with_target']}\n"

mining_report += f"""
## Clustering Results
- Optimal k from Silhouette Score: **{best_k}**
- Silhouette Score at k={best_k}: **{silhouette_scores[best_k-2]:.4f}**
- Davies-Bouldin Score at k={best_k}: **{db_scores[best_k-2]:.4f}**

### Cluster Profiles (mean values)
"""
for cluster_id in range(best_k):
    profile = cluster_profiles.loc[cluster_id]
    mining_report += f"**Cluster {cluster_id}** (n={sum(cluster_labels==cluster_id)}):\n"
    for col in top_features_pca[:5]:
        if col in profile.index:
            val = profile[col]
            mining_report += f"  - {col}: {val:.2f}\n"

mining_report += f"""
## Anomalies Detected
- **{n_anomalies} anomalies** found ({n_anomalies/len(df)*100:.1f}% of data)

## Association Patterns (Top 10)
"""
for ap in assoc_patterns[:10]:
    mining_report += f"- If **{ap['if']}** → **{ap['then']}** (confidence: {ap['confidence']})\n"

mining_report += f"""
## Business Implications
"""
# Generate business implications based on findings
if target_corr:
    top_target_feat = target_corr[0]['feature']
    top_target_val = target_corr[0]['corr_with_target']
    mining_report += f"""
1. **Target Correlation**: '{top_target_feat}' shows {top_target_val:.2f} correlation with target — this is the strongest predictor
"""
if n_anomalies > 0:
    mining_report += f"""
2. **Anomaly Patterns**: {n_anomalies} unusual records detected — investigate these for data quality issues or special cases
"""
mining_report += f"""
3. **Segments Found**: {best_k} distinct employee groups identified through clustering — each has different characteristic profiles

## Recommended Actions
- Use cluster profiles for targeted interventions
- Investigate anomaly records for data quality or special business cases
- Focus on features with strongest correlation to target
"""

with open(os.path.join(OUTPUT_DIR, 'mining_results.md'), 'w', encoding='utf-8') as f:
    f.write(mining_report)
print("[STATUS] Saved mining_results.md")

# ---- patterns_found.md ----
patterns_report = f"""Patterns Found — Max Data Mining
==================================
Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}

## Pattern Type: Correlation

"""
# Add correlation patterns
for cp in corr_pairs[:5]:
    patterns_report += f"""### Pattern: {cp['col1']} ↔ {cp['col2']}
**Evidence**: Correlation coefficient = {cp['correlation']}
**Category**: Strong {'positive' if cp['correlation'] > 0 else 'negative'} relationship
**Business Implication**: Changes in {cp['col1']} strongly relate to changes in {cp['col2']}
**Actionable**: {'Yes' if abs(cp['correlation']) > 0.7 else 'Monitor'}

"""

patterns_report += f"""
## Pattern Type: Clustering Groups

### Pattern: {best_k} Distinct Employee Segments
**Evidence**: K-Means with silhouette score {silhouette_scores[best_k-2]:.4f}
"""
for cluster_id in range(best_k):
    profile = cluster_profiles.loc[cluster_id]
    cluster_size = sum(cluster_labels==cluster_id)
    patterns_report += f"""**Cluster {cluster_id}** ({cluster_size} employees — {cluster_size/len(df)*100:.1f}%):
"""
    for col in top_features_pca[:3]:
        if col in profile.index:
            patterns_report += f"  - Avg {col}: {profile[col]:.2f}\n"

patterns_report += f"""
## Pattern Type: Anomalies

### Pattern: {n_anomalies} Anomalous Records Detected
