    print("[STATUS] Not a standard model comparison. Attempting general insight extraction.")
    # ... (keep existing fallback code)
    pass

# ── 7. Save output CSV ───────────────────────────────────────
output_csv = os.path.join(OUTPUT_DIR, 'iris_output.csv')
