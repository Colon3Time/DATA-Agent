print("\n[STATUS] ---- PHASE 4: Elbow Method for K-Means ----")

# Use PCA-reduced data for clustering if many features
if feature_data.shape[1] > 10:
    X_cluster = X_pca[:, :n_components_95]
    print(f"[STATUS] Using {n_components_95} PCA components for clustering")
else:
    X_cluster = X_scaled
    print("[STATUS] Using original scaled features for clustering")

inertias = []
silhouettes = []
K_range = range(2, min(11, X_cluster.shape[0] // 2 + 1))

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X_cluster)
    inertias.append(km.inertia_)
    
    if k > 1 and len(set(labels)) > 1 and len(set(labels)) < len(labels):
        try:
            sil = silhouette_score(X_cluster, labels)
            silhouettes.append(sil)
        except:
            silhouettes.append(0)
    else:
        silhouettes.append(0)

# Find elbow point
if len(inertias) >= 2:
    diffs = np.diff(inertias)
    diffs2 = np.diff(diffs)
    if len(diffs2) > 0:
        elbow_k = np.argmax(diffs2) + 2  # +2 because diff reduces by 2
    else:
        elbow_k = 2
    print(f"[STATUS] Suggested elbow point: k = {elbow_k}")

# Plot elbow
plt.figure(figsize=(12, 5))
plt.subplot(1, 2, 1)
plt.plot(list(K_range), inertias, 'bo-')
plt.axvline(x=elbow_k, color='r', linestyle='--', alpha=0.5)
plt.xlabel('Number of Clusters')
plt.ylabel('Inertia')
plt.title('Elbow Method')
plt.grid(True, alpha=0.3)

plt.subplot(1, 2, 2)
plt.plot(list(K_range), silhouettes, 'go-')
plt.xlabel('Number of Clusters')
plt.ylabel('Silhouette Score')
plt.title('Silhouette Score')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow_method.png'), dpi=100)
plt.close()
print(f"[STATUS] Elbow method plot saved, optimal k ≈ {elbow_k}")

# ============================================================
# 5. FINAL K-MEANS CLUSTERING
# ============================================================
print("\n[STATUS] ---- PHASE 5: K-Means Clustering ----")

best_k = elbow_k if elbow_k >= 2 else 3
km_final = KMeans(n_clusters=best_k, random_state=42, n_init=10)
cluster_labels = km_final.fit_predict(X_cluster)
df['Cluster'] = cluster_labels

sil_final = silhouette_score(X_cluster, cluster_labels)
db_final = davies_bouldin_score(X_cluster, cluster_labels)
print(f"[STATUS] Final clustering: k={best_k}, Silhouette={sil_final:.3f}, Davies-Bouldin={db_final:.3f}")

# Cluster profiles
cluster_profiles = []
for cluster_id in range(best_k):
    mask = df['Cluster'] == cluster_id
    cluster_df = df[mask]
    profile = {
        'cluster_id': cluster_id,
        'size': len(cluster_df),
        'percentage': round(100 * len(cluster_df) / len(df), 1)
    }
    
    # Add numeric means
    for col in numeric_cols[:10]:  # Limit to top 10 numeric for readability
        if col in cluster_df.columns:
            profile[f'mean_{col}'] = round(cluster_df[col].mean(), 2)
    
    cluster_profiles.append(profile)

for cp in cluster_profiles:
    print(f"  Cluster {cp['cluster_id']}: {cp['size']} employees ({cp['percentage']}%)")

# PCA visualization of clusters
plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.6, s=30)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]*100:.1f}%)')
plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]*100:.1f}%)')
plt.title(f'Cluster Visualization (k={best_k})')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'cluster_pca.png'), dpi=100)
plt.close()
print("[STATUS] Cluster PCA plot saved")

# ============================================================
# 6. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 6: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42)
anomaly_labels = iso_forest.fit_predict(X_scaled)
anomaly_scores = iso_forest.decision_function(X_scaled)

df['Anomaly'] = anomaly_labels
df['Anomaly_Score'] = anomaly_scores

n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({100*n_anomalies/len(df):.1f}%)")

# Top anomalies
anomaly_df = df[df['Anomaly'] == -1].copy()
if not anomaly_df.empty:
    print("\nTop anomalies (by anomaly score):")
    top_anomalies = anomaly_df.nsmallest(10, 'Anomaly_Score')
    for idx, row in top_anomalies.iterrows():
        print(f"  Row {idx}: score={row['Anomaly_Score']:.3f}")

# ============================================================
# 7. PATTERN DISCOVERY
# ============================================================
print("\n[STATUS] ---- PHASE 7: Pattern Discovery ----")

patterns = []
pattern_id = 1

# Pattern A: Target analysis (if target exists)
if target_cols:
    target_col = target_cols[0]
    if target_col in df.columns:
        target_rate = df[target_col].mean()
        print(f"[STATUS] Target rate: {target_rate:.2%}")
        
        patterns.append({
            'id': pattern_id,
            'pattern': f'Overall target rate is {target_rate:.1%}',
            'evidence': f'Mean of {target_col}: {target_rate:.3f}',
            'importance': 'High',
            'business_implication': f'This indicates the baseline {target_col} rate across the organization',
            'recommended_action': 'Investigate departments with higher than average rates'
        })
        pattern_id += 1
        
        # Target by cluster
        if target_col in df.columns:
            for cluster_id in range(best_k):
                mask = df['Cluster'] == cluster_id
                cluster_target = df[mask][target_col].mean()
                if abs(cluster_target - target_rate) > 0.05:
                    patterns.append({
                        'id': pattern_id,
                        'pattern': f'Cluster {cluster_id} has {target_col} rate of {cluster_target:.1%} vs avg {target_rate:.1%}',
                        'evidence': f'Difference = {cluster_target - target_rate:.1%}',
                        'importance': 'High',
                        'business_implication': f'This cluster may need targeted intervention',
                        'recommended_action': f'Analyze Cluster {cluster_id} characteristics to develop retention strategies'
                    })
                    pattern_id += 1

# Pattern B: Cluster characteristics
for cp in cluster_profiles:
    patterns.append({
        'id': pattern_id,
        'pattern': f'Cluster {cp["cluster_id"]} represents {cp["percentage"]}% of employees ({cp["size"]} employees)',
        'evidence': f'Cluster size: {cp["size"]}',
        'importance': 'Medium',
        'business_implication': f'This is a significant employee segment that may need tailored management',
        'recommended_action': f'Profile and understand the needs of Cluster {cp["cluster_id"]}'
    })
    pattern_id += 1

# Pattern C: High correlations
for p in high_corr_pairs[:5]:
    patterns.append({
        'id': pattern_id,
        'pattern': f'Strong correlation: {p["col1"]} ↔ {p["col2"]} ({p["correlation"]})',
        'evidence': f'Correlation coefficient: {p["correlation"]}',
        'importance': 'Medium' if abs(p['correlation']) > 0.7 else 'Low',
        'business_implication': 'These variables are strongly related and may be used as proxies for each other',
        'recommended_action': 'Consider if one variable can be used to predict or explain the other'
    })
    pattern_id += 1

# Pattern D: Anomaly patterns
if n_anomalies > 0:
    patterns.append({
        'id': pattern_id,
        'pattern': f'{n_anomalies} anomalies detected ({100*n_anomalies/len(df):.1f}% of data)',
        'evidence': f'Isolation Forest contamination=0.05 detected {n_anomalies} outliers',
        'importance': 'Medium',
        'business_implication': 'These employees/devices show unusual behavior patterns that need investigation',
        'recommended_action': 'Review top anomalies for root cause analysis'
    })
    pattern_id += 1

# ============================================================
# 8. SAVE MINING RESULTS REPORT
# ============================================================
print("\n[STATUS] ---- PHASE 8: Saving Reports ----")

mining_results_path = os.path.join(OUTPUT_DIR, 'mining_results.md')
with open(mining_results_path, 'w', encoding='utf-8') as f:
    f.write(f"""# Max Data Mining Report
**Generated:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
**Input:** {os.path.basename(INPUT_PATH)}

## Summary
- **Data Shape:** {df.shape[0]} rows × {df.shape[1]} columns
- **Clusters Found:** {best_k} (Silhouette: {sil_final:.3f})
- **Anomalies Detected:** {n_anomalies} ({100*n_anomalies/len(df):.1f}%)
- **High Correlations Found:** {len(high_corr_pairs)} pairs

## Techniques Used
1. **Correlation Analysis** — Pearson correlation matrix
2. **Dimensionality Reduction** — PCA ({n_components_95} components to explain 95% variance)
3. **K-Means Clustering** — Optimal k via Elbow Method
4. **Anomaly Detection** — Isolation Forest (contamination=0.05)

## Clustering Results
| Cluster | Size | % of Data |
|---------|------|-----------|
""")
    for cp in cluster_profiles:
        f.write(f"| {cp['cluster_id']} | {cp['size']} | {cp['percentage']}% |\n")
    
    f.write(f"""
**Quality Metrics:**
- Silhouette Score: {sil_final:.3f}
- Davies-Bouldin Score: {db_final:.3f}

## Key Patterns Found
""")
    
    for p in patterns:
        f.write(f"""
### Pattern {p['id']}: {p['pattern']}
- **Evidence:** {p['evidence']}
- **Importance:** {p['importance']}
- **Business Implication:** {p['business_implication']}
- **Recommended Action:** {p['recommended_action']}
""")

print(f"[STATUS] Mining results saved to {mining_results_path}")

# ============================================================
# 9. SAVE PATTERNS FOUND REPORT
# ============================================================
patterns_found_path = os.path.join(OUTPUT_DIR, 'patterns_found.md')
with open(patterns_found_path, 'w', encoding='utf-8') as f:
    f.write(f"""# Patterns Found Report
**Date:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

## Pattern Summary
Total Patterns Discovered: {len(patterns)}

""")
    
    importance_order = {'High': 1, 'Medium': 2, 'Low': 3}
    sorted_patterns = sorted(patterns, key=lambda x: importance_order.get(x['importance'], 99))
    
    for i, p in enumerate(sorted_patterns, 1):
        f.write(f"""### Pattern {i}: {p['pattern']}
| Field | Value |
|-------|-------|
| **Importance** | {p['importance']} |
| **Evidence** | {p['evidence']} |
| **Business Implication** | {p['business_implication']} |
| **Recommended Action** | {p['recommended_action']} |

""")

print(f"[STATUS] Patterns found saved to {patterns_found_path}")

# ============================================================
# 10. SELF-IMPROVEMENT REPORT
# ============================================================
print("\n[STATUS] ---- PHASE 9: Self-Improvement Report ----")

improvement_report_path = os.path.join(OUTPUT_DIR, 'self_improvement.md')
with open(improvement_report_path, 'w', encoding='utf-8') as f:
    f.write(f"""# Max Self-Improvement Report
**Date:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

## Methods Used This Session
1. **K-Means Clustering** — with Elbow Method for optimal k selection
2. **Isolation Forest** — for anomaly detection
3. **PCA** — for dimensionality reduction and visualization

## Performance Assessment
- Clustering quality: {'Good' if sil_final > 0.5 else 'Fair'} (Silhouette = {sil_final:.3f})
- Anomaly detection: {n_anomalies} anomalies found ({100*n_anomalies/len(df):.1f}%)

## Lessons Learned
- PCA helped reduce dimensionality while preserving 95% of variance
- Elbow method with silhouette score provided reliable k selection
- High correlation pairs identified which help explain feature relationships

## Knowledge Base Updates
- Pattern: Standard pipeline established (correlation → PCA → clustering → anomaly)
- Suggestion: For future sessions with similar data, use same pipeline

## Recommendations for Next Time
- Try DBSCAN if clusters have irregular shapes
- Use Association Rules if transactional data available
- Consider t-SNE for better cluster visualization
""")

print(f"[STATUS] Self-improvement report saved to {improvement_report_path}")

# ============================================================
# 11. SAVE CSV OUTPUT
# ============================================================
output_csv = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(output_csv, index=False)
print(f"[STATUS] Output CSV saved to {output_csv}")

print("\n[STATUS] ==== MAX DATA MINING COMPLETE ====")
print(f"[STATUS] Files generated:")
print(f"  - {mining_results_path}")
print(f"  - {patterns_found_path}")
print(f"  - {improvement_report_path}")
print(f"  - {output_csv}")
print(f"  - correlation_heatmap.png")
print(f"  - pca_variance.png")
print(f"  - elbow_method.png")
print(f"  - cluster_pca.png")
