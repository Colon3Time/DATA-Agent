with open(os.path.join(OUTPUT_DIR, 'self_improvement.md'), 'w', encoding='utf-8') as f:
    f.write(improvement_report)
print("[STATUS] Self-improvement report saved")

print("\n[STATUS] === ALL TASKS COMPLETED SUCCESSFULLY ===")
