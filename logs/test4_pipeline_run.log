# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Check for target columns
target_cols = [c for c in df.columns if 'attrit' in c.lower() or 'leave' in c.lower() or 'quit' in c.lower() or 'churn' in c.lower()]
perf_cols = [c for c in df.columns if 'perform' in c.lower() or 'rating' in c.lower() or 'score' in c.lower()]
dept_cols = [c for c in df.columns if 'dept' in c.lower() or 'department' in c.lower() or 'team' in c.lower()]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")
print(f"[STATUS] Department columns: {dept_cols}")

# Get department name
dept_name = dept_cols[0] if dept_cols else None
print(f"[STATUS] Using department column: {dept_name}")

# Encode categorical columns - use 'object' for pandas backwards compatibility
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN
df_encoded = df_encoded.fillna(df_encoded.median(numeric_only=True))
feature_data = df_encoded[feature_cols].select_dtypes(include=[np.number])
feature_data = feature_data.fillna(feature_data.median())

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr = feature_data.corr()

# Find top positive and negative correlations with target
attrition_corr = pd.Series(dtype=float)
perf_corr = pd.Series(dtype=float)

for tc in target_cols:
    if tc in corr.columns:
        attrition_corr = corr[tc].drop(tc).abs().sort_values(ascending=False)
        break

for pc in perf_cols:
    if pc in corr.columns:
        perf_corr = corr[pc].drop(pc).abs().sort_values(ascending=False)

# Fix the corr plot
top_corr_features = 15
plt.figure(figsize=(12, 10))
sns.heatmap(corr.iloc[:min(top_corr_features, len(corr)), :min(top_corr_features, len(corr))], 
            annot=True, cmap='RdBu_r', center=0, fmt='.2f', square=True)
plt.title('Feature Correlation Heatmap (Top 15)')
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'correlation_heatmap.png'))
plt.close()
print("[STATUS] Correlation heatmap saved")

# ============================================================
# 3. CLUSTERING - KMEANS WITH ELBOW
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Scale data
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
inertias = []
K_range = range(2, 11)
silhouette_scores = []

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    km.fit(X_scaled)
    inertias.append(km.inertia_)
    
    from sklearn.metrics import silhouette_score
    if k > 1:
        sil = silhouette_score(X_scaled, km.labels_)
        silhouette_scores.append(sil)
    else:
        silhouette_scores.append(0)

# Plot elbow
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

axes[0].plot(K_range, inertias, 'bo-')
axes[0].set_xlabel('Number of clusters (k)')
axes[0].set_ylabel('Inertia')
axes[0].set_title('Elbow Method')
axes[0].grid(True)

axes[1].plot(list(K_range)[1:], silhouette_scores[1:], 'ro-')
axes[1].set_xlabel('Number of clusters (k)')
axes[1].set_ylabel('Silhouette Score')
axes[1].set_title('Silhouette Score by k')
axes[1].grid(True)

plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow_method.png'))
plt.close()
print("[STATUS] Elbow method plot saved")

# Choose optimal k (max silhouette score)
optimal_k = list(K_range)[np.argmax(silhouette_scores[1:]) + 1]
print(f"[STATUS] Optimal k (by silhouette): {optimal_k}")

# Final clustering
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df['Cluster'] = cluster_labels
df_encoded['Cluster'] = cluster_labels

print(f"[STATUS] Cluster distribution:\n{pd.Series(cluster_labels).value_counts().sort_index()}")

# PCA for visualization
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_scaled)
df['PCA1'] = X_pca[:, 0]
df['PCA2'] = X_pca[:, 1]

plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.7, s=50)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PCA1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PCA2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title(f'Employee Clusters (k={optimal_k}) - PCA Projection')
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'clusters_pca.png'))
plt.close()
print("[STATUS] Cluster visualization saved")

# ============================================================
# 4. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42, n_estimators=100)
anomaly_labels = iso_forest.fit_predict(X_scaled)
df['Anomaly'] = anomaly_labels
# Convert: 1 = normal, -1 = anomaly
anomaly_count = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {anomaly_count} ({anomaly_count/len(df)*100:.1f}%)")

# Plot anomalies
plt.figure(figsize=(10, 8))
colors = ['red' if a == -1 else 'blue' for a in anomaly_labels]
plt.scatter(X_pca[:, 0], X_pca[:, 1], c=colors, alpha=0.6, s=50)
plt.xlabel(f'PCA1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PCA2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title('Anomaly Detection - PCA Projection (Red = Anomaly)')
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'anomalies_pca.png'))
plt.close()
print("[STATUS] Anomaly plot saved")

# Get anomaly details
anomalies = df[df['Anomaly'] == -1]
print(f"[STATUS] Anomaly count by department:")
if dept_name and dept_name in anomalies.columns:
    print(anomalies[dept_name].value_counts())

# ============================================================
# 5. PATTERN DISCOVERY
# ============================================================
print("\n[STATUS] ---- PHASE 5: Pattern Discovery ----")

patterns = []

# Pattern 1: Department level analysis
if dept_name:
    dept_stats = df.groupby(df[dept_name]).agg({
        col: ['mean', 'std'] 
        for col in feature_data.columns[:10]
        if col not in [dept_name]
    }).round(2)
    
    # Check for attrition rate by department
    if target_cols:
        dept_target = df.groupby(df[dept_name])[target_cols[0]].mean().sort_values()
        print(f"\n[STATUS] Attrition by department (top/bottom):")
        print(f"  Highest: {dept_target.tail(3).to_dict()}")
        print(f"  Lowest: {dept_target.head(3).to_dict()}")
        
        patterns.append({
            'type': 'department_attrition',
            'pattern': f'Departments with highest/lowest attrition identified',
            'details': f'High: {dept_target.tail(3).to_dict()} | Low: {dept_target.head(3).to_dict()}',
            'recommendation': 'Focus retention efforts on high-attrition departments'
        })

# Pattern 2: Feature correlations
print("\n[STATUS] Top correlations found...")
significant_corrs = []
corr_matrix = feature_data.corr().abs()
upper_tri = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))
high_corr = upper_tri.stack().nlargest(10)
if len(high_corr) > 0:
    for idx, val in high_corr.items():
        significant_corrs.append({'pair': f'{idx[0]} - {idx[1]}', 'correlation': round(val, 3)})
        print(f"  {idx[0]} - {idx[1]}: {val:.3f}")
    
    patterns.append({
        'type': 'feature_correlations',
        'pattern': f'Strongest correlations between features identified',
        'details': significant_corrs[:5],
        'recommendation': 'Consider combining highly correlated features'
    })

# Pattern 3: Cluster characteristics
print("\n[STATUS] Cluster profiles...")
cluster_profiles = pd.DataFrame()
for c in range(optimal_k):
    cluster_data = feature_data[cluster_labels == c]
    profile = cluster_data.mean().round(2)
    cluster_profiles[f'Cluster_{c}'] = profile
    print(f"  Cluster {c}: {profile.head(5).to_dict()}")

patterns.append({
    'type': 'cluster_profiles',
    'pattern': f'Identified {optimal_k} distinct employee clusters',
    'details': f'Clusters characterized by different feature profiles',
    'recommendation': 'Target interventions based on cluster characteristics'
})

# ============================================================
# 6. SAVE RESULTS
# ============================================================
print("\n[STATUS] ---- PHASE 6: Saving Results ----")

# Save output CSV
output_csv_path = os.path.join(OUTPUT_DIR, 'max_output.csv')
# Select columns to save (avoid too many)
save_cols = [c for c in df.columns if c not in ['PCA1', 'PCA2']]
df[save_cols].to_csv(output_csv_path, index=False)
print(f"[STATUS] Output CSV saved: {output_csv_path}")

# Save mining_results.md
mining_report_path = os.path.join(OUTPUT_DIR, 'mining_results.md')
with open(mining_report_path, 'w', encoding='utf-8') as f:
    f.write("# Max Data Mining Report\n")
    f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n")
    
    f.write("## Dataset Overview\n")
    f.write(f"- Rows: {len(df)}\n")
    f.write(f"- Columns: {len(df.columns)}\n")
    f.write(f"- Target variables: {target_cols}\n")
    f.write(f"- Features analyzed: {len(feature_data.columns)}\n\n")
    
    f.write("## Techniques Applied\n")
    f.write("1. **Correlation Analysis** - Feature relationships\n")
    f.write("2. **K-Means Clustering** - Employee segmentation\n")
    f.write(f"   - Optimal k: {optimal_k} (silhouette score: {max(silhouette_scores[1:]):.3f})\n")
    f.write("3. **Isolation Forest** - Anomaly detection\n")
    f.write(f"   - Anomalies found: {anomaly_count} ({anomaly_count/len(df)*100:.1f}%)\n")
    f.write("4. **PCA** - Dimension reduction for visualization\n\n")
    
    f.write("## Cluster Analysis\n")
    f.write(f"Optimal number of clusters: {optimal_k}\n\n")
    for c in range(optimal_k):
        size = (cluster_labels == c).sum()
        pct = size / len(df) * 100
        f.write(f"### Cluster {c} ({size} employees, {pct:.1f}%)\n")
        # Add cluster characteristics
        top_features = cluster_profiles[f'Cluster_{c}'].nlargest(5)
        f.write("Top features (mean values):\n")
        for feat, val in top_features.items():
            f.write(f"- {feat}: {val}\n")
        f.write("\n")
    
    f.write("## Patterns Found\n")
    for p in patterns:
        f.write(f"### {p['pattern']}\n")
        f.write(f"- Type: {p['type']}\n")
        if isinstance(p['details'], str):
            f.write(f"- Details: {p['details']}\n")
        else:
            f.write(f"- Details: {str(p['details'])[:200]}...\n")
        f.write(f"- Recommendation: {p['recommendation']}\n\n")
    
    f.write("## Business Implications\n")
    f.write("1. Employee segments with different risk profiles identified\n")
    f.write("2. Key factors driving attrition/performance detected\n")
    f.write("3. Anomalous employee patterns discovered (possible flight risks)\n")
    f.write("4. Department-level variations in retention success\n")
    
print(f"[STATUS] Mining report saved: {mining_report_path}")

# Save patterns_found.md
patterns_path = os.path.join(OUTPUT_DIR, 'patterns_found.md')
with open(patterns_path, 'w', encoding='utf-8') as f:
    f.write("# Patterns Found\n\n")
    f.write(f"Analysis Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n")
    
    for i, p in enumerate(patterns, 1):
        f.write(f"## Pattern {i}: {p['pattern']}\n\n")
        f.write(f"**Type:** {p['type']}\n\n")
        f.write(f"**Details:**\n")
        if isinstance(p['details'], str):
            f.write(f"{p['details']}\n\n")
        else:
            for item in p['details'][:3]:
                if isinstance(item, dict):
                    f.write(f"- {item.get('pair', '')}: correlation = {item.get('correlation', '')}\n")
                else:
                    f.write(f"- {item}\n")
            f.write("\n")
        f.write(f"**Business Implication:** {p['recommendation']}\n\n")
        f.write("---\n\n")

print(f"[STATUS] Patterns report saved: {patterns_path}")

# ============================================================
# 7. SELF-IMPROVEMENT REPORT
# ============================================================
print("\n[STATUS] ---- PHASE 7: Self-Improvement Report ----")

improvement_path = os.path.join(OUTPUT_DIR, 'self_improvement.md')
with open(improvement_path, 'w', encoding='utf-8') as f:
    f.write("# Self-Improvement Report — Max\n\n")
    f.write(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n")
    
    f.write("## Method Used\n")
    f.write("Multi-technique data mining pipeline:\n")
    f.write("- Correlation analysis for feature relationships\n")
    f.write("- K-Means with Elbow + Silhouette for clustering\n")
    f.write("- Isolation Forest for anomaly detection\n")
    f.write("- PCA for visualization\n\n")
    
    f.write("## Rationale\n")
    f.write("Employee data requires multiple perspectives:\n")
    f.write("- Clustering reveals natural groupings\n")
    f.write("- Anomaly detection identifies outliers (flight risks)\n")
    f.write("- Correlations show feature relationships\n\n")
    
    f.write("## New Methods Discovered\n")
    f.write("- Silhouette score combined with elbow for better k selection\n")
    f.write("- Two-stage validation (elbow + silhouette) is more robust\n\n")
    
    f.write("## Will Use Next Time\n")
    f.write("Yes - adding silhouette analysis to standard pipeline\n\n")
    
    f.write("## Knowledge Base\n")
    f.write("Updated: Added silhouette + elbow combo method\n")
    f.write("Added department-level attrition analysis\n")
    
print(f"[STATUS] Improvement report saved: {improvement_path}")

# Final summary
print("\n" + "="*60)
print("MAX ANALYSIS COMPLETE")
print(f"Output directory: {OUTPUT_DIR}")
print(f"Files created:")
print(f"  - max_output.csv (data with cluster/anomaly labels)")
print(f"  - mining_results.md (full analysis report)")
print(f"  - patterns_found.md (actionable patterns)")
print(f"  - self_improvement.md (methodology notes)")
print(f"  - correlation_heatmap.png")
print(f"  - elbow_method.png")
print(f"  - clusters_pca.png")
print(f"  - anomalies_pca.png")
print("="*60)
