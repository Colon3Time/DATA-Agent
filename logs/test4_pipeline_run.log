import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Handle .md input — find CSV in parent
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/dana_output.csv')) + sorted(parent.glob('**/*_output.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f"[STATUS] Resolved .md input → CSV: {INPUT_PATH}")

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Identify key columns
target_cols = [c for c in df.columns if any(k in c.lower() for k in ['attrit', 'leave', 'quit', 'churn', 'target', 'label'])]
dept_cols = [c for c in df.columns if any(k in c.lower() for k in ['dept', 'department', 'team'])]
perf_cols = [c for c in df.columns if any(k in c.lower() for k in ['perform', 'rating', 'score', 'efficien'])]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Department columns: {dept_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str', 'category']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id', 'employee', 'name_emp']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN — only numeric columns
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

# Drop columns with zero variance
feature_data = feature_data.loc[:, feature_data.nunique() > 1]
numeric_cols = feature_data.columns.tolist()

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")

# ============================================================
# 2. SCALING
# ============================================================
print("\n[STATUS] ---- PHASE 2: Scaling Features ----")
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)
print(f"[STATUS] Scaled data shape: {X_scaled.shape}")

# ============================================================
# 3. PCA FOR DIMENSIONALITY REDUCTION
# ============================================================
print("\n[STATUS] ---- PHASE 3: PCA ----")
n_features = X_scaled.shape[1]
n_components = min(n_features, min(10, X_scaled.shape[0] - 1))
if n_components < 2:
    n_components = min(n_features, X_scaled.shape[0] - 1)

if n_components >= 2:
    pca = PCA(n_components=n_components)
    X_pca = pca.fit_transform(X_scaled)
    
    # Create PCA components dataframe safely
    n_rows_for_index = min(pca.components_.shape[0], len(numeric_cols))
    pca_components = pd.DataFrame(
        pca.components_[:n_rows_for_index, :],
        columns=[f'PC{i+1}' for i in range(pca.components_.shape[1])],
        index=numeric_cols[:n_rows_for_index]
    )
    
    print(f"[STATUS] PCA variance explained: {pca.explained_variance_ratio_}")
    print(f"[STATUS] PCA components shape: {pca_components.shape}")
    
    # Plot variance explained
    plt.figure(figsize=(10, 6))
    plt.bar(range(1, len(pca.explained_variance_ratio_) + 1), pca.explained_variance_ratio_)
    plt.plot(range(1, len(pca.explained_variance_ratio_) + 1), np.cumsum(pca.explained_variance_ratio_), 'ro-')
    plt.xlabel('Principal Component')
    plt.ylabel('Variance Explained Ratio')
    plt.title('PCA Variance Explained')
    plt.tight_layout()
    plt.savefig(os.path.join(OUTPUT_DIR, 'pca_variance.png'))
    plt.close()
    print("[STATUS] Saved PCA variance plot")
else:
    X_pca = X_scaled
    print("[STATUS] Too few features/components for PCA")

# ============================================================
# 4. ELBOW METHOD FOR K-MEANS
# ============================================================
print("\n[STATUS] ---- PHASE 4: Elbow Method ----")
inertias = []
silhouette_scores = []
K_range = range(2, min(11, X_scaled.shape[0]))
for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X_scaled)
    inertias.append(km.inertia_)
    if len(set(labels)) > 1:
        sil = silhouette_score(X_scaled, labels)
    else:
        sil = 0
    silhouette_scores.append(sil)

# Plot elbow
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
axes[0].plot(K_range, inertias, 'bo-')
axes[0].set_xlabel('Number of Clusters')
axes[0].set_ylabel('Inertia')
axes[0].set_title('Elbow Method')
axes[1].plot(K_range, silhouette_scores, 'ro-')
axes[1].set_xlabel('Number of Clusters')
axes[1].set_ylabel('Silhouette Score')
axes[1].set_title('Silhouette Analysis')
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow.png'))
plt.close()
print("[STATUS] Saved Elbow Method plot")

# ============================================================
# 5. K-MEANS CLUSTERING (AUTO-SELECT K)
# ============================================================
print("\n[STATUS] ---- PHASE 5: K-Means Clustering ----")
# Find best k: max silhouette score
if len(silhouette_scores) > 0:
    best_k = list(K_range)[np.argmax(silhouette_scores)]
    print(f"[STATUS] Best K (silhouette): {best_k}")

    km_final = KMeans(n_clusters=best_k, random_state=42, n_init=10)
    cluster_labels = km_final.fit_predict(X_scaled)
    df['Cluster'] = cluster_labels
    
    # Cluster stats
    cluster_profile = df.groupby('Cluster').agg(['mean', 'std', 'count']).round(2)
    print(f"[STATUS] Cluster sizes: {df['Cluster'].value_counts().to_dict()}")
    
    # Silhouette score
    sil_final = silhouette_score(X_scaled, cluster_labels)
    db_final = davies_bouldin_score(X_scaled, cluster_labels)
    print(f"[STATUS] Silhouette Score: {sil_final:.4f}")
    print(f"[STATUS] Davies-Bouldin Index: {db_final:.4f}")

    # Visualize clusters with PCA
    if X_pca.shape[1] >= 2:
        plt.figure(figsize=(10, 8))
        scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.6)
        plt.colorbar(scatter, label='Cluster')
        plt.xlabel('PC1')
        plt.ylabel('PC2')
        plt.title(f'Customer Segments (K-Means, k={best_k})')
        plt.tight_layout()
        plt.savefig(os.path.join(OUTPUT_DIR, 'cluster_visualization.png'))
        plt.close()
        print("[STATUS] Saved cluster visualization")

# ============================================================
# 6. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 6: Anomaly Detection ----")
iso_forest = IsolationForest(contamination=0.05, random_state=42)
anomaly_labels = iso_forest.fit_predict(X_scaled)
df['Anomaly'] = anomaly_labels
n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies}")
print(f"[STATUS] Normal samples: {len(anomaly_labels) - n_anomalies}")

# ============================================================
# 7. PATTERN DISCOVERY
# ============================================================
print("\n[STATUS] ---- PHASE 7: Pattern Discovery ----")

# Pattern 1: Correlation with target variables
patterns = []
if target_cols:
    target = target_cols[0]
    correlations = feature_data.corrwith(df_encoded[target]).sort_values(key=abs, ascending=False)
    top_corr = correlations.head(5)
    patterns.append({
        'pattern': f"Top features correlated with {target}",
        'details': top_corr.to_dict(),
        'implication': f"These features most strongly influence {target}"
    })
    print(f"[STATUS] Top correlations with {target}: {top_corr.to_dict()}")

# Pattern 2: Cluster characteristics
if 'Cluster' in df.columns:
    cluster_summary = {}
    for k in sorted(df['Cluster'].unique()):
        cluster_data = df[df['Cluster'] == k]
        cluster_size = len(cluster_data)
        summary = {'size': cluster_size, 'pct': round(100 * cluster_size / len(df), 1)}
        
        # Get top numeric features for this cluster
        numeric_for_summary = feature_data.iloc[cluster_data.index].mean()
        top_features = numeric_for_summary.nlargest(3).to_dict()
        summary['top_features'] = top_features
        
        # If target exists, get its mean in cluster
        if target_cols:
            summary[f'avg_{target_cols[0]}'] = round(cluster_data[target_cols[0]].mean(), 3)
        
        cluster_summary[f'Cluster {k}'] = summary
    
    patterns.append({
        'pattern': 'Cluster profiles identified',
        'details': cluster_summary,
        'implication': 'Distinct employee segments found with different characteristics'
    })

# Pattern 3: Association between department and performance/attrition
if dept_cols and perf_cols:
    dept_col = dept_cols[0]
    perf_col = perf_cols[0]
    
    dept_perf = df.groupby(dept_col)[perf_col].agg(['mean', 'std', 'count'])
    top_dept = dept_perf.nlargest(3, 'mean')
    patterns.append({
        'pattern': f"Top departments by {perf_col}",
        'details': top_dept.to_dict(),
        'implication': 'These departments show highest performance scores'
    })

# Pattern 4: Anomaly profile
anomaly_df = df[df['Anomaly'] == -1]
normal_df = df[df['Anomaly'] == 1]
if len(anomaly_df) > 0 and len(normal_df) > 0:
    anomaly_numeric = anomaly_df.select_dtypes(include=[np.number]).mean()
    normal_numeric = normal_df.select_dtypes(include=[np.number]).mean()
    diff = (anomaly_numeric - normal_numeric).abs().sort_values(ascending=False)
    top_diff = diff.head(3)
    patterns.append({
        'pattern': 'Anomaly characteristics',
        'details': top_diff.to_dict(),
        'implication': 'These features differentiate anomalies from normal samples'
    })

# ============================================================
# 8. SAVE OUTPUTS
# ============================================================
print("\n[STATUS] ---- PHASE 8: Saving Outputs ----")

# Save enriched dataset
output_csv = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(output_csv, index=False)
print(f"[STATUS] Saved: {output_csv}")

# Save mining_results.md
results_md = f"""# Max Data Mining Report — Employee Analysis

**Generated:** {datetime.now().strftime('%Y-%m-%d %H:%M')}

## Techniques Used
- K-Means Clustering (k={best_k if 'best_k' in dir() else 'N/A'})
