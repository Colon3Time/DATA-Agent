        else:
            df[attrition_col] = df[attrition_col].astype(int)

        dept_attrition = df.groupby(dept_col)[attrition_col].agg(['mean', 'count']).reset_index()
        dept_attrition.columns = [dept_col, 'attrition_rate', 'employee_count']
