    # Get top 15 positions by count for readability
    pos_counts = df_clean[position_col].value_counts()
    top_positions = pos_counts.head(15).index.tolist()
    
    plot_df = df_clean[df_clean[position_col].isin(top_positions)].copy()
    
    # Order by median salary
    medians = plot_df.groupby(position_col)[salary_col].median().sort_values()
    plot_df[position_col] = pd.Categorical(plot_df[position_col], categories=medians.index, ordered=True)
    
    bp = sns.boxplot(x=position_col, y=salary_col, data=plot_df, palette='coolwarm', ax=ax)
    bp.set_xticklabels(bp.get_xticklabels(), rotation=45, ha='right', fontsize=9)
    
    # Add median values on top
    for i, pos in enumerate(medians.index):
