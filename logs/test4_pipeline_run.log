    plt.close()
    print(f'[STATUS] Chart 1 saved: {chart1_path}')
    
    # Store for report
    dept_high = attr_dept.iloc[-1]
    dept_low = attr_dept.iloc[0]
else:
    print('[WARNING] Missing dept or attrition column, creating bar chart of categorical data')
    # Fallback: show any categorical column's distribution
    cat_cols = [c for c in df_clean.columns if df_clean[c].dtype == 'object' and df_clean[c].nunique() <= 15]
    if cat_cols:
