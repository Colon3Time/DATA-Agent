# ============================================================
# 5. PATTERN EXTRACTION — Association Rules between features
# ============================================================
print("\n[STATUS] ---- PHASE 5: Pattern Extraction ----")

# Discretize numeric features into quartiles for pattern mining
df_patterns = df.copy()
pattern_cols = []
for col in feature_data.columns[:10]:  # limit to top 10 features
    if pd.api.types.is_numeric_dtype(df[col]):
        q_col = f'{col}_q'
        df_patterns[q_col] = pd.qcut(df[col], q=4, labels=['Q1', 'Q2', 'Q3', 'Q4'], duplicates='drop')
        pattern_cols.append(q_col)

# Add target and dept columns if they exist
if target_col:
    df_patterns[target_col] = df[target_col]
    pattern_cols.append(target_col)
if dept_name and dept_name in df.columns:
    df_patterns[dept_name] = df[dept_name]

# Encode patterns for counting
pattern_data = df_patterns[pattern_cols].copy()
for col in pattern_data.columns:
    le = LabelEncoder()
    pattern_data[col] = le.fit_transform(pattern_data[col].astype(str))

# Find most common pattern combinations
from itertools import combinations

pattern_frequencies = {}
for combo_size in [2, 3]:
    for combo in combinations(pattern_data.columns, combo_size):
        combo_df = pattern_data[list(combo)]
        # Group by all columns and count
        freq = combo_df.value_counts().reset_index()
        freq.columns = list(combo) + ['count']
        freq['support'] = freq['count'] / len(df)
        
        for _, row in freq.iterrows():
            if row['support'] >= 0.05:  # min support 5%
                combo_str = ' & '.join([f"{col}={int(row[col])}" for col in combo])
                pattern_frequencies[combo_str] = {
                    'count': int(row['count']),
                    'support': float(row['support'])
                }

# Sort patterns by support
sorted_patterns = sorted(pattern_frequencies.items(), key=lambda x: x[1]['support'], reverse=True)
print(f"[STATUS] Found {len(sorted_patterns)} patterns with support >= 0.05")
for p, v in sorted_patterns[:10]:
    print(f"  Pattern: {p} -> support={v['support']:.3f}, count={v['count']}")

