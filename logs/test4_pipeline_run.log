        importance_vals = df[feature_importances]
        feature_data = pd.DataFrame({'feature': feature_names, 'importance': importance_vals})
else:
    # Try to infer feature importances from any numeric summary table
    for col in df.columns:
        if df[col].dtype == object:
            # Check if this looks like feature name
            candidate = df[col]
            key_col = col
            numeric_cols = [c for c in df.columns if df[c].dtype in [np.float64, np.int64, float, int] and c != col]
            if len(numeric_cols) > 0 and len(df) <= 50:
                # Use the first numeric column as importance
                importance_col = numeric_cols[0]
                feature_data = pd.DataFrame({
                    'feature': df[key_col],
                    'importance': np.abs(df[importance_col])
                })
                break

if feature_data is not None and len(feature_data) > 0:
    feature_data = feature_data.sort_values('importance', ascending=True).tail(20)
    fig, ax = plt.subplots(figsize=(10, max(6, len(feature_data) * 0.35)))
    colors = plt.cm.YlOrRd(np.linspace(0.3, 0.9, len(feature_data)))
    bars = ax.barh(feature_data['feature'].astype(str), feature_data['importance'], color=colors, edgecolor='white')
    for bar, val in zip(bars, feature_data['importance']):
        ax.annotate(f'{val:.3f}',
                    xy=(bar.get_width(), bar.get_y() + bar.get_height() / 2),
                    xytext=(5, 0), textcoords="offset points",
                    ha='left', va='center', fontsize=8)
    ax.set_title('Feature Importance', fontsize=14, fontweight='bold')
    ax.set_xlabel('Importance', fontsize=11)
    plt.tight_layout()
    plt.savefig(os.path.join(CHARTS_DIR, 'feature_importance.png'), dpi=150, bbox_inches='tight')
    plt.close()
    print('[STATUS] Chart 4: feature_importance.png saved')
else:
    # Create a synthetic feature importance from correlations
    numeric_df = df.select_dtypes(include=[np.number])
    if len(numeric_df.columns) >= 3:
        target = attrition_col if attrition_col and len(numeric_df.columns) > 2 else numeric_df.columns[-1]
        if target in numeric_df.columns:
            corr = numeric_df.corr()[target].drop(target).abs().sort_values(ascending=False).head(15)
            if len(corr) > 0:
                fig, ax = plt.subplots(figsize=(10, 6))
                colors = plt.cm.YlOrRd(np.linspace(0.3, 0.9, len(corr)))
                bars = ax.barh(corr.index, corr.values, color=colors, edgecolor='white')
                for bar, val in zip(bars, corr.values):
                    ax.annotate(f'{val:.3f}',
                                xy=(bar.get_width(), bar.get_y() + bar.get_height() / 2),
                                xytext=(5, 0), textcoords="offset points",
                                ha='left', va='center', fontsize=8)
                ax.set_title(f'Feature Importance (Correlation with {target})', fontsize=14, fontweight='bold')
                ax.set_xlabel('|Correlation|', fontsize=11)
                plt.tight_layout()
                plt.savefig(os.path.join(CHARTS_DIR, 'feature_importance.png'), dpi=150, bbox_inches='tight')
                plt.close()
                print('[STATUS] Chart 4: feature_importance.png saved (from correlation)')
            else:
                print('[STATUS] Skipped chart 4: no valid features for importance')
        else:
            print('[STATUS] Skipped chart 4: could not determine feature importance')
    else:
        print('[STATUS] Skipped chart 4: insufficient numeric columns')

