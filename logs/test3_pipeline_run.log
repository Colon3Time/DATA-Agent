```python
import argparse, os, pandas as pd
import numpy as np
from pathlib import Path
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
parser.add_argument('--save-script', default='')
parser.add_argument('--save-report', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input if args.input else r'C:\Users\Amorntep\DATA-Agent\projects\2026-04-25_test3\output\finn\finn_output.csv'
OUTPUT_DIR = args.output_dir if args.output_dir else r'C:\Users\Amorntep\DATA-Agent\projects\2026-04-25_test3\output\mo'
os.makedirs(OUTPUT_DIR, exist_ok=True)

SCRIPT_PATH = args.save_script if args.save_script else os.path.join(OUTPUT_DIR, 'mo_script.py')
REPORT_PATH = args.save_report if args.save_report else os.path.join(OUTPUT_DIR, 'mo_report.md')
OUTPUT_CSV = os.path.join(OUTPUT_DIR, 'mo_output.csv')

df = pd.read_csv(INPUT_PATH)
print(f'[STATUS] Loaded: {df.shape}')

# === [1] Explore Data ===
print(f'[STATUS] Columns: {list(df.columns)}')
print(f'[STATUS] Dtypes:\n{df.dtypes}')
print(f'[STATUS] Nulls:\n{df.isnull().sum()}')
print(f'[STATUS] Target distributions:')
if 'return_flag' in df.columns:
    print(df['return_flag'].value_counts(normalize=True))
if 'total_amount' in df.columns:
    print(f'total_amount stats:\n{df["total_amount"].describe()}')

# Clean column names
df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_')
df.columns = df.columns.str.replace(r'[^a-z0-9_]', '', regex=True)
print(f'[STATUS] Cleaned columns: {list(df.columns)}')

# Handle date columns
date_cols = [c for c in df.columns if 'date' in c or 'at' in c.lower()]
for c in date_cols:
    try:
        df[c] = pd.to_datetime(df[c], errors='coerce')
    except:
        pass

# === [2] Prepare Features ===
drop_cols = [c for c in df.columns if c in ['customerid', 'customer_id', 'transactionid', 'transaction_id', 'userid', 'user_id']]
if 'total_amount' in df.columns:
    drop_cols.append('total_amount')
if 'return_flag' in df.columns:
    drop_cols.append('return_flag')
    
# Add date features
for c in date_cols:
    if c in df.columns and pd.api.types.is_datetime64_any_dtype(df[c]):
        df[f'{c}_year'] = df[c].dt.year
        df[f'{c}_month'] = df[c].dt.month
        df[f'{c}_day'] = df[c].dt.day
        df[f'{c}_dayofweek'] = df[c].dt.dayofweek
        drop_cols.append(c)

# Encode categorical
cat_cols = df.select_dtypes(include=['object']).columns.tolist()
for c in cat_cols:
    if c not in drop_cols:
        df[c] = df[c].astype('category').cat.codes

# Fill remaining nulls
df = df.fillna(df.median(numeric_only=True))

# Define targets
target_reg = 'total_amount' if 'total_amount' in df.columns else None
target_cls = 'return_flag' if 'return_flag' in df.columns else None

print(f'[STATUS] Drop cols: {drop_cols}')
X_cols = [c for c in df.columns if c not in drop_cols and c != target_reg and c != target_cls]
print(f'[STATUS] Feature cols ({len(X_cols)}): {X_cols[:10]}...')

# === [3] Train Models ===
from sklearn.model_selection import cross_val_score, StratifiedKFold, KFold
from sklearn.metrics import f1_score, accuracy_score, roc_auc_score, r2_score, mean_squared_error, mean_absolute_error
from sklearn.linear_model import LogisticRegression, LinearRegression, Ridge, Lasso
from sklearn.ensemble import RandomForestClassifier, RandomForestRegressor
from xgboost import XGBClassifier, XGBRegressor
from sklearn.preprocessing import StandardScaler
from sklearn.pipeline import Pipeline

results = []

# === Regression: total_amount ===
if target_reg and target_reg in df.columns:
    y_reg = df[target_reg].values
    X_reg = df[X_cols].values
    print(f'[STATUS] Regression X: {X_reg.shape}, y: {y_reg.shape}')
    
    reg_models = [
        ('Linear Regression', LinearRegression()),
        ('Ridge', Ridge(alpha=1.0)),
        ('Lasso', Lasso(alpha=0.1)),
        ('Random Forest Reg', RandomForestRegressor(n_estimators=100, random_state=42)),
        ('XGBoost Reg', XGBRegressor(n_estimators=100, random_state=42, verbosity=0)),
    ]
    
    cv_reg = KFold(n_splits=5, shuffle=True, random_state=42)
    
    for name, model in reg_models:
        try:
            if name in ['Linear Regression', 'Ridge', 'Lasso']:
                pipe = Pipeline([('scaler', StandardScaler()), ('model', model)])
            else:
                pipe = model
            
            rmse_scores = []
            mae_scores = []
            r2_scores = []
            
            for train_idx, val_idx in cv_reg.split(X_reg):
                X_tr, X_val = X_reg[train_idx], X_reg[val_idx]
                y_tr, y_val = y_reg[train_idx], y_reg[val_idx]
                
                if name in ['Linear Regression', 'Ridge', 'Lasso']:
                    scaler = StandardScaler()
                    X_tr_scaled = scaler.fit_transform(X_tr)
                    X_val_scaled = scaler.transform(X_val)
                    model.fit(X_tr_scaled, y_tr)
                    y_pred = model.predict(X_val_scaled)
                else:
                    model.fit(X_tr, y_tr)
                    y_pred = model.predict(X_val)
                
                rmse_scores.append(np.sqrt(mean_squared_error(y_val, y_pred)))
                mae_scores.append(mean_absolute_error(y_val, y_pred))
                r2_scores.append(r2_score(y_val, y_pred))
            
            results.append({
                'Task': 'Regression',
                'Model': name,
                'RMSE': f'{np.mean(rmse_scores):.4f} ± {np.std(rmse_scores):.4f}',
                'MAE': f'{np.mean(mae_scores):.4f} ± {np.std(mae_scores):.4f}',
                'R2': f'{np.mean(r2_scores):.4f} ± {np.std(r2_scores):.4f}',
                'Time_Score': 0
            })
            print(f'[STATUS] {name}: R2={np.mean(r2_scores):.4f}')
        except Exception as e:
            print(f'[STATUS] {name} failed: {e}')

# === Classification: return_flag ===
if target_cls and target_cls in df.columns:
    y_cls = df[target_cls].values
    X_cls = df[X_cols].values
    
    # Handle if y is 0/1
    if len(np.unique(y_cls)) > 2:
        print(f'[STATUS] Multi-class classification detected: {len(np.unique(y_cls))} classes')
    else:
        print(f'[STATUS] Binary classification: {np.unique(y_cls)}')
    
    cls_models = [
        ('Logistic Regression', LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced')),
        ('Random Forest', RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced')),
        ('XGBoost', XGBClassifier(n_estimators=100, random_state=42, eval_metric='logloss', verbosity=0)),
    ]
    
    cv_cls = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    for name, model in cls_models:
        try:
            if name == 'Logistic Regression':
                pipe = Pipeline([('scaler', StandardScaler()), ('model', model)])
            else:
                pipe = model
            
            f1_scores = []
            acc_scores = []
            auc_scores = []
            
            for train_idx, val_idx in cv_cls.split(X_cls, y_cls):
                X_tr, X_val = X_cls[train_idx], X_cls[val_idx]
                y_tr, y_val = y_cls[train_idx], y_cls[val_idx]
                
                if name == 'Logistic Regression':
                    scaler = StandardScaler()
                    X_tr_scaled = scaler.fit_transform(X_tr)
                    X_val_scaled = scaler.transform(X_val)
                    model.fit(X_tr_scaled, y_tr)
                    y_pred = model.predict(X_val_scaled)
                    y_proba = model.predict_proba(X_val_scaled)
                else:
                    model.fit(X_tr, y_tr)
                    y_pred = model.predict(X_val)
                    y_proba = model.predict_proba(X_val)
                
                f1_scores.append(f1_score(y_val, y_pred, average='weighted'))
                acc_scores.append(accuracy_score(y_val, y_pred))
                
                if len(np.unique(y_cls)) == 2 and y_proba.shape[1] == 2:
                    auc_scores.append(roc_auc_score(y_val, y_proba[:, 1]))
                else:
                    try:
                        auc_scores.append(roc_auc_score(y_val, y_proba, multi_class='ovr'))
                    except:
                        auc_scores.append(0)
            
            results.append({
                'Task': 'Classification',
                'Model': name,
                'F1_weighted': f'{np.mean(f1_scores):.4f} ± {np.std(f1_scores):.4f}',
                'Accuracy': f'{np.mean(acc_scores):.4f} ± {np.std(acc_scores):.4f}',
                'AUC': f'{np.mean(auc_scores):.4f} ± {np.std(auc_scores):.4f}',
                'Time_Score': 1
            })
            print(f'[STATUS] {name}: F1={np.mean(f1_scores):.4f}, AUC={np.mean(auc_scores):.4f}')
        except Exception as e:
            print(f'[STATUS] {name} failed: {e}')

# === [4] Feature Importance from Best Model ===
print('[STATUS] Extracting feature importances from best tree-based model...')
best_model = None

if target_cls and target_cls in df.columns:
    print(f'[STATUS] Training best classification model for feature importance...')
    best_rf = RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced')
    best_rf.fit(X_cls, y_cls)
    importances = best_rf.feature_importances_
    fi_df = pd.DataFrame({'feature': X_cols, 'importance': importances}).sort_values('importance', ascending=False)
    print(f'[STATUS] Top 10 features:\n{fi_df.head(10).to_string()}')

elif target_reg and target_reg in df.columns:
    print(f'[STATUS] Training best regression model for feature importance...')
    best_rf = RandomForestRegressor(n_estimators=100, random_state=42)
    best_rf.fit(X_reg, y_reg)
    importances = best_rf.feature_importances_
    fi_df = pd.DataFrame({'feature': X_cols, 'importance': importances}).sort_values('importance', ascending=False)
    print(f'[STATUS] Top 10 features:\n{fi_df.head(10).to_string()}')

# === [5] Build Output CSV with predictions ===
print('[STATUS] Building output CSV with predictions...')
output_df = pd.DataFrame()
for col in df.columns:
    if col in [target_reg, target_cls]:
        output_df[f'actual_{col}'] = df[col].values

# Add feature importances
if 'fi_df' in dir():
    output_df['feature_rank'] = 0

# Add some predictions from best model
