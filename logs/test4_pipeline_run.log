import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Handle .md input — find CSV in parent
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/dana_output.csv')) + sorted(parent.glob('**/*_output.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f"[STATUS] Resolved .md input → CSV: {INPUT_PATH}")

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Identify key columns
target_cols = [c for c in df.columns if any(k in c.lower() for k in ['attrit', 'leave', 'quit', 'churn', 'target', 'label'])]
dept_cols = [c for c in df.columns if any(k in c.lower() for k in ['dept', 'department', 'team'])]
perf_cols = [c for c in df.columns if any(k in c.lower() for k in ['perform', 'rating', 'score', 'efficien'])]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Department columns: {dept_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str', 'category']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id', 'employee', 'name_emp']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN — only numeric columns
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")
print(f"[STATUS] Numeric feature count: {len(numeric_cols)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr_matrix = feature_data.corr()
corr_threshold = 0.5
high_corr_pairs = []
for i in range(len(corr_matrix.columns)):
    for j in range(i+1, len(corr_matrix.columns)):
        if abs(corr_matrix.iloc[i, j]) >= corr_threshold:
            high_corr_pairs.append({
                'feature1': corr_matrix.columns[i],
                'feature2': corr_matrix.columns[j],
                'correlation': round(corr_matrix.iloc[i, j], 3)
            })

print(f"[STATUS] Found {len(high_corr_pairs)} high correlation pairs (|r|>={corr_threshold})")
for pair in high_corr_pairs[:10]:
    print(f"  {pair['feature1']} <-> {pair['feature2']}: {pair['correlation']}")

# Save correlation heatmap
plt.figure(figsize=(16, 14))
sns.heatmap(corr_matrix, annot=False, cmap='RdBu_r', center=0, square=True)
plt.title('Feature Correlation Matrix', fontsize=16)
plt.tight_layout()
corr_path = os.path.join(OUTPUT_DIR, 'correlation_matrix.png')
plt.savefig(corr_path, dpi=150, bbox_inches='tight')
plt.close()
print(f"[STATUS] Correlation heatmap saved: {corr_path}")

# ============================================================
# 3. SCALE DATA FOR CLUSTERING
# ============================================================
print("\n[STATUS] ---- PHASE 3: Scaling ----")

scaler = StandardScaler()
feature_scaled = scaler.fit_transform(feature_data)
feature_scaled_df = pd.DataFrame(feature_scaled, columns=feature_data.columns)

# ============================================================
# 4. PCA FOR DIMENSIONALITY REDUCTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: PCA ----")

n_components = min(feature_scaled.shape[1], 10)
pca = PCA(n_components=n_components)
pca_result = pca.fit_transform(feature_scaled)
explained_var_ratio = pca.explained_variance_ratio_
cumulative_var = np.cumsum(explained_var_ratio)

print(f"[STATUS] PCA explained variance: {cumulative_var[:5]}")

# Plot PCA variance
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
axes[0].bar(range(1, len(explained_var_ratio)+1), explained_var_ratio)
axes[0].set_xlabel('Principal Component')
axes[0].set_ylabel('Explained Variance Ratio')
axes[0].set_title('PCA Variance by Component')
axes[1].plot(range(1, len(cumulative_var)+1), cumulative_var, 'bo-')
axes[1].axhline(y=0.8, color='r', linestyle='--', alpha=0.7, label='80% threshold')
axes[1].set_xlabel('Number of Components')
axes[1].set_ylabel('Cumulative Variance')
axes[1].set_title('Cumulative Explained Variance')
axes[1].legend()
plt.tight_layout()
pca_path = os.path.join(OUTPUT_DIR, 'pca_variance.png')
plt.savefig(pca_path, dpi=150, bbox_inches='tight')
plt.close()
print(f"[STATUS] PCA variance plot saved: {pca_path}")

# Use enough components to explain 80% variance
n_keep = np.argmax(cumulative_var >= 0.8) + 1 if any(cumulative_var >= 0.8) else n_components
pca_final = PCA(n_components=n_keep)
pca_data = pca_final.fit_transform(feature_scaled)
print(f"[STATUS] Using {n_keep} PCA components (explains {cumulative_var[n_keep-1]:.1%} variance)")

# ============================================================
# 5. K-MEANS CLUSTERING WITH ELBOW
# ============================================================
print("\n[STATUS] ---- PHASE 5: K-Means Clustering ----")

# Elbow method
inertias = []
silhouettes = []
K_range = range(2, min(11, len(feature_scaled) - 1))

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(pca_data)
    inertias.append(km.inertia_)
    if len(set(labels)) > 1 and k < len(feature_scaled):
        sil = silhouette_score(pca_data, labels)
        silhouettes.append(sil)
    else:
        silhouettes.append(0)

# Plot elbow curve
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
axes[0].plot(list(K_range), inertias, 'bo-')
axes[0].set_xlabel('Number of clusters (k)')
axes[0].set_ylabel('Inertia')
axes[0].set_title('Elbow Method for Optimal k')
axes[0].grid(True)

if silhouettes:
    axes[1].plot(list(K_range)[:len(silhouettes)], silhouettes, 'ro-')
    axes[1].set_xlabel('Number of clusters (k)')
    axes[1].set_ylabel('Silhouette Score')
    axes[1].set_title('Silhouette Analysis')
    axes[1].grid(True)
else:
    axes[1].text(0.5, 0.5, 'Not enough data for silhouette', ha='center', va='center')

plt.tight_layout()
elbow_path = os.path.join(OUTPUT_DIR, 'elbow_method.png')
plt.savefig(elbow_path, dpi=150, bbox_inches='tight')
plt.close()
print(f"[STATUS] Elbow plot saved: {elbow_path}")

# Choose optimal k — prefer elbow point or max silhouette
if silhouettes:
    best_k = list(K_range)[np.argmax(silhouettes)]
else:
    # Simple elbow detection
    diffs = np.diff(inertias)
    best_k = list(K_range)[np.argmin(diffs) + 1]

print(f"[STATUS] Optimal k = {best_k}")

# Final clustering
kmeans = KMeans(n_clusters=best_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(pca_data)

# Add cluster to data
df['Cluster'] = cluster_labels
df_encoded['Cluster'] = cluster_labels

# Evaluate cluster quality
sil_score = silhouette_score(pca_data, cluster_labels)
db_score = davies_bouldin_score(pca_data, cluster_labels)
print(f"[STATUS] Silhouette Score: {sil_score:.3f} (>0.5 good, >0.7 excellent)")
print(f"[STATUS] Davies-Bouldin Score: {db_score:.3f} (<1 good)")

# Cluster profiles using original feature values
cluster_means = df.groupby('Cluster')[feature_data.columns].mean()
cluster_counts = df['Cluster'].value_counts().sort_index()
print(f"[STATUS] Cluster sizes: {cluster_counts.to_dict()}")

print("\n[STATUS] Cluster Profiles (feature means):")
print(cluster_means.round(2))

# ============================================================
# 6. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 6: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42)
anomaly_labels = iso_forest.fit_predict(pca_data)
df['Anomaly'] = anomaly_labels
n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({n_anomalies/len(df)*100:.1f}%)")

# Find anomalous records — get top anomalies by anomaly score
anomaly_scores = iso_forest.decision_function(pca_data)
df['Anomaly_Score'] = anomaly_scores
df['Is_Anomaly'] = anomaly_labels == -1
anomaly_df = df[df['Is_Anomaly']].sort_values('Anomaly_Score')

# Print sample anomalies (first 5)
print(f"[STATUS] Sample anomalies (first 5):")
if len(anomaly_df) > 0:
    for i, (idx, row) in enumerate(anomaly_df.head(5).iterrows()):
        print(f"  Anomaly {i+1}: Index {idx}")

# ============================================================
# 7. PATTERN DISCOVERY — Feature Importance
# ============================================================
print("\n[STATUS] ---- PHASE 7: Pattern Discovery ----")

# Find which features most differentiate clusters
cluster_center_df = pd.DataFrame(
    scaler.inverse_transform(kmeans.cluster_centers_[:, :len(feature_data.columns)]),
    columns=feature_data.columns[:len(kmeans.cluster_centers_[0])]
)
# Actually use PCA inverse
from sklearn.preprocessing import StandardScaler
# Reconstruct cluster means in original space
cluster_means_in_scaled = kmeans.cluster_centers_
cluster_means_original = scaler.inverse_transform(
    pca_final.inverse_transform(cluster_means_in_scaled)
)
cluster_center_df = pd.DataFrame(cluster_means_original, columns=feature_data.columns)

# Find top differentiating features for each cluster
top_patterns = []
for cluster_id in range(best_k):
    cluster_center = cluster_center_df.iloc[cluster_id]
    global_mean = feature_data.mean()
    diff = (cluster_center - global_mean).abs().sort_values(ascending=False)
    top_features = diff.head(5).index.tolist()
    top_diffs = diff.head(5).values.tolist()
    
    pattern = {
        'cluster': int(cluster_id),
        'size': int(cluster_counts[cluster_id]),
        'percentage': round(cluster_counts[cluster_id] / len(df) * 100, 1),
        'top_differentiating_features': top_features,
        'feature_differences': [round(d, 2) for d in top_diffs]
    }
    top_patterns.append(pattern)
    print(f"\n[PATTERN] Cluster {cluster_id} ({pattern['size']} employees, {pattern['percentage']}%):")
    for feat, diff in zip(top_features, top_diffs):
        direction = "HIGH" if cluster_center[feat] > global_mean[feat] else "LOW"
        print(f"  {feat}: {direction} (diff: {diff:.2f})")

# ============================================================
# 8. CORRELATION-BASED PATTERNS
# ============================================================
print("\n[STATUS] ---- PHASE 8: Correlation Patterns ----")

# Top correlations with target if exists
if target_cols:
    target = target_cols[0]
    target_corrs = corr_matrix[target].drop(target).sort_values(ascending=False)
    print(f"[STATUS] Top correlations with '{target}':")
    for col, corr in target_corrs.head(5).items():
        print(f"  {col}: {corr:.3f}")
    
    # Save top correlations
    top_corr_with_target = target_corrs.head(10).reset_index()
    top_corr_with_target.columns = ['Feature', 'Correlation']
else:
    # Find features most correlated with clusters
    cluster_corrs = []
    for col in numeric_cols:
        try:
            corr_val = df[col].corr(df['Cluster'])
            cluster_corrs.append({'feature': col, 'correlation_with_cluster': round(corr_val, 3)})
        except:
            pass
    cluster_corr_df = pd.DataFrame(cluster_corrs).sort_values('correlation_with_cluster', ascending=False, key=abs)
    print(f"[STATUS] Top features correlated with clusters:")
    for _, row in cluster_corr_df.head(5).iterrows():
        print(f"  {row['feature']}: {row['correlation_with_cluster']:.3f}")

# ============================================================
# 9. SAVE RESULTS
# ============================================================
print("\n[STATUS] ---- PHASE 9: Saving Results ----")

# Save enhanced data
output_csv = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(output_csv, index=False)
print(f"[STATUS] Saved: {output_csv}")

# Save mining results report
now = datetime.now().strftime('%Y-%m-%d %H:%M')
cluster_size_summary = {f'Cluster {k}': {'count': int(v), 'pct': round(v/len(df)*100, 1)} 
                        for k, v in cluster_counts.items()}

mining_report = f"""# Max Data Mining Report
**Generated:** {now}

## Executive Summary
- **Dataset:** {len(df)} records, {len(feature_data.columns)} features
- **Clusters Found:** {best_k} clusters
- **Anomalies Detected:** {n_anomalies} ({n_anomalies/len(df)*100:.1f}%)
