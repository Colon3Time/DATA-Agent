normal_df = df[df['Anomaly'] == 1]

# Compare means between anomalies and normal
anomaly_means = anomaly_df[feature_data.columns].mean()
normal_means = normal_df[feature_data.columns].mean()
anomaly_diff = (anomaly_means - normal_means).sort_values(ascending=False)

print(f"[STATUS] Top features different in anomalies:")
for col, diff_val in anomaly_diff.head(8).items():
    direction = "higher" if diff_val > 0 else "lower"
    print(f"  {col}: {abs(diff_val):.2f} ({direction})")

# Plot anomaly scores
