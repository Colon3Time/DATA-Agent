import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Handle .md input — find CSV in parent
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/dana_output.csv')) + sorted(parent.glob('**/*_output.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f"[STATUS] Resolved .md input → CSV: {INPUT_PATH}")

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Identify key columns
target_cols = [c for c in df.columns if any(k in c.lower() for k in ['attrit', 'leave', 'quit', 'churn', 'target', 'label'])]
dept_cols = [c for c in df.columns if any(k in c.lower() for k in ['dept', 'department', 'team'])]
perf_cols = [c for c in df.columns if any(k in c.lower() for k in ['perform', 'rating', 'score', 'efficien'])]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Department columns: {dept_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id', 'employee', 'name_emp']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN — only numeric columns
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")
print(f"[STATUS] Numeric feature count: {len(numeric_cols)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr_matrix = feature_data.corr()
# Find high correlations
high_corr_pairs = []
for i in range(len(corr_matrix.columns)):
    for j in range(i+1, len(corr_matrix.columns)):
        val = corr_matrix.iloc[i, j]
        if abs(val) > 0.5:
            high_corr_pairs.append((corr_matrix.columns[i], corr_matrix.columns[j], val))

print(f"[STATUS] Found {len(high_corr_pairs)} high correlation pairs (|r| > 0.5)")
for pair in high_corr_pairs[:10]:
    print(f"  {pair[0]} <-> {pair[1]}: r = {pair[2]:.3f}")

# Save correlation plot
plt.figure(figsize=(12, 10))
sns.heatmap(corr_matrix, annot=False, cmap='RdBu_r', center=0, square=True)
plt.title('Feature Correlation Matrix', fontsize=14)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'correlation_heatmap.png'), dpi=100)
plt.close()
print("[STATUS] Correlation heatmap saved")

# ============================================================
# 3. CLUSTERING ANALYSIS WITH ELBOW METHOD
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
inertias = []
K_range = range(2, 11)
sil_scores = []
for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X_scaled)
    inertias.append(km.inertia_)
    if k > 1 and len(set(labels)) > 1:
        sil_scores.append(silhouette_score(X_scaled, labels))
    else:
        sil_scores.append(-1)

# Find optimal k
best_k = K_range[np.argmax(sil_scores)] if any(s > 0 for s in sil_scores) else 3
# Find elbow point using rate of change
diffs = np.diff(inertias)
diffs2 = np.diff(diffs)
elbow_idx = np.argmax(diffs2) + 2 if len(diffs2) > 0 else 2
elbow_k = K_range[min(elbow_idx, len(K_range)-1)]
optimal_k = max(2, min(best_k, elbow_k))

print(f"[STATUS] Elbow method suggests k = {elbow_k}")
print(f"[STATUS] Silhouette best k = {best_k}")
print(f"[STATUS] Using k = {optimal_k}")

# Plot Elbow Method
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))
ax1.plot(K_range, inertias, 'bo-')
ax1.axvline(x=optimal_k, color='r', linestyle='--', alpha=0.7)
ax1.set_xlabel('Number of clusters (k)')
ax1.set_ylabel('Inertia')
ax1.set_title('Elbow Method')
ax1.grid(True, alpha=0.3)

ax2.plot(K_range, sil_scores, 'go-')
ax2.axvline(x=optimal_k, color='r', linestyle='--', alpha=0.7)
ax2.set_xlabel('Number of clusters (k)')
ax2.set_ylabel('Silhouette Score')
ax2.set_title('Silhouette Score by k')
ax2.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow_method.png'), dpi=100)
plt.close()
print("[STATUS] Elbow method plot saved")

# Final clustering
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df['Cluster'] = cluster_labels

# Evaluate clustering
sil_score = silhouette_score(X_scaled, cluster_labels)
db_score = davies_bouldin_score(X_scaled, cluster_labels)
print(f"[STATUS] Silhouette Score: {sil_score:.4f}")
print(f"[STATUS] Davies-Bouldin Score: {db_score:.4f}")

# Cluster profiles
print(f"\n[STATUS] Cluster Distribution:")
cluster_counts = df['Cluster'].value_counts().sort_index()
for cl, cnt in cluster_counts.items():
    pct = 100 * cnt / len(df)
    print(f"  Cluster {cl}: {cnt} ({pct:.1f}%)")

# Cluster means
cluster_means = df.groupby('Cluster')[numeric_cols].mean()
print(f"\n[STATUS] Cluster Profiles (top features):")
for cl in cluster_means.index:
    top_features = cluster_means.loc[cl].sort_values(ascending=False).head(5)
    print(f"  Cluster {cl}: {dict(top_features)}")

# PCA for visualization
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_scaled)
df['PCA1'] = X_pca[:, 0]
df['PCA2'] = X_pca[:, 1]

plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.7, s=50)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title(f'Employee Clusters (k={optimal_k}) — PCA Projection')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'cluster_pca.png'), dpi=100)
plt.close()
print("[STATUS] Cluster PCA plot saved")

# ============================================================
# 4. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.1, random_state=42, n_estimators=100)
anomaly_labels = iso_forest.fit_predict(X_scaled)
df['Anomaly'] = anomaly_labels

n_anomalies = (anomaly_labels == -1).sum()
n_normal = (anomaly_labels == 1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({100*n_anomalies/len(df):.1f}%)")
print(f"[STATUS] Normal points: {n_normal} ({100*n_normal/len(df):.1f}%)")

# Anomaly profile
anomaly_df = df[df['Anomaly'] == -1]
normal_df = df[df['Anomaly'] == 1]

if len(anomaly_df) > 0 and len(normal_df) > 0:
    # Calculate means safely
    anomaly_means = anomaly_df[numeric_cols].mean(numeric_only=True)
    normal_means = normal_df[numeric_cols].mean(numeric_only=True)
    diff = (anomaly_means - normal_means).abs().sort_values(ascending=False)
    
    print(f"[STATUS] Top features distinguishing anomalies:")
    for feat in diff.head(5).index:
        print(f"  {feat}: anomaly_mean={anomaly_means[feat]:.3f}, normal_mean={normal_means[feat]:.3f}")

# Anomaly visualization
plt.figure(figsize=(10, 8))
colors = ['red' if l == -1 else 'blue' for l in anomaly_labels]
plt.scatter(X_pca[:, 0], X_pca[:, 1], c=colors, alpha=0.6, s=50)
plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title('Anomaly Detection — PCA Projection (Red = Anomaly)')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'anomaly_pca.png'), dpi=100)
plt.close()
print("[STATUS] Anomaly plot saved")

# ============================================================
# 5. PATTERN DISCOVERY
# ============================================================
print("\n[STATUS] ---- PHASE 5: Pattern Discovery ----")

# Find strong associations in target columns (if exist)
patterns_found = []
if target_cols:
    target_corrs = []
    for t_col in target_cols:
        if t_col in feature_data.columns:
            for f_col in numeric_cols:
                if f_col != t_col:
                    r = feature_data[t_col].corr(feature_data[f_col])
                    if abs(r) > 0.2:
                        target_corrs.append((t_col, f_col, r))
    
    target_corrs.sort(key=lambda x: abs(x[2]), reverse=True)
    print(f"[STATUS] Top correlations with target variable:")
    for t, f, r in target_corrs[:10]:
        direction = "positive" if r > 0 else "negative"
        print(f"  {t} vs {f}: r = {r:.3f} ({direction})")
        patterns_found.append({
            'pattern': f'{f} has {direction} correlation with {t} (r={r:.3f})',
            'evidence': f'Pearson correlation coefficient = {r:.3f}',
            'importance': 'high' if abs(r) > 0.3 else 'medium'
        })

# Department-based patterns
if dept_cols:
    dept_col = dept_cols[0]
    if dept_col in df.columns:
        dept_groups = df.groupby(dept_col)[numeric_cols].mean()
        print(f"\n[STATUS] Department profiles (mean values across {len(dept_groups)} departments):")
        for dept in dept_groups.index[:5]:
            top_vals = dept_groups.loc[dept].sort_values(ascending=False).head(3)
            print(f"  {dept}: {dict(top_vals)}")
            patterns_found.append({
                'pattern': f'{dept} department shows distinct profile in key metrics',
                'evidence': f'Mean values: {dict(top_vals)}',
                'importance': 'medium'
            })

# Cluster-based patterns
for cl in range(optimal_k):
    cl_size = (cluster_labels == cl).sum()
    cl_pct = 100 * cl_size / len(df)
    
    # Find distinguishing features for this cluster vs others
    cl_mean = cluster_means.loc[cl]
    other_means = cluster_means.drop(cl).mean()
    diff = (cl_mean - other_means).abs().sort_values(ascending=False)
    
    top_diff_features = diff.head(3)
    feature_descriptions = []
    for feat in top_diff_features.index:
        direction = "higher" if cl_mean[feat] > other_means[feat] else "lower"
        feature_descriptions.append(f"{feat} is {direction}")
    
    patterns_found.append({
        'pattern': f'Cluster {cl} ({cl_pct:.1f}%): {", ".join(feature_descriptions)}',
        'evidence': f'{cl_size} employees ({cl_pct:.1f}%)',
        'importance': 'high' if cl_pct > 15 else 'medium'
    })

# Save patterns
patterns_df = pd.DataFrame(patterns_found)
patterns_path = os.path.join(OUTPUT_DIR, 'patterns_found.csv')
patterns_df.to_csv(patterns_path, index=False)
print(f"\n[STATUS] Saved {len(patterns_found)} patterns to {patterns_path}")

# ============================================================
# 6. SAVE RESULTS
# ============================================================
print("\n[STATUS] ---- PHASE 6: Saving Results ----")

# Save clustering results
output_csv = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(output_csv, index=False)
print(f"[STATUS] Saved output CSV: {output_csv}")

# Save mining results report
mining_report = f"""# Max Data Mining Report

## Overview
- **Input file**: {INPUT_PATH}
