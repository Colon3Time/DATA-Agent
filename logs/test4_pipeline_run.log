plt.hist(anomaly_scores, bins=50, alpha=0.7, edgecolor='black')
plt.axvline(x=np.percentile(anomaly_scores, 5), color='r', linestyle='--', label='5th percentile (anomaly threshold)')
plt.xlabel('Anomaly Score (higher = more normal)', fontsize=12)
plt.ylabel('Frequency', fontsize=12)
plt.title('Anomaly Score Distribution — Isolation Forest', fontsize=14, fontweight='bold')
plt.legend()
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'anomaly_distribution.png'), dpi=150)
plt.close()
