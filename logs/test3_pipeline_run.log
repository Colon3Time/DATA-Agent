import argparse
import os
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import seaborn as sns
import numpy as np
from pathlib import Path

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir

# Create output directories
os.makedirs(OUTPUT_DIR, exist_ok=True)
CHART_DIR = os.path.join(OUTPUT_DIR, 'charts')
os.makedirs(CHART_DIR, exist_ok=True)

# Load data
df = pd.read_csv(INPUT_PATH)
print(f'[STATUS] Loaded data: {df.shape}')
print(f'[STATUS] Columns: {list(df.columns)}')
print(f'[STATUS] Dtypes:\n{df.dtypes}')
print(f'[STATUS] First 5 rows:\n{df.head()}')

# ---- Step 1: Data Exploration & Cleaning ----
# Check for missing values
print(f'[STATUS] Missing values:\n{df.isnull().sum()}')

# Detect numeric columns
numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
categorical_cols = df.select_dtypes(include=['object']).columns.tolist()
print(f'[STATUS] Numeric columns: {numeric_cols}')
print(f'[STATUS] Categorical columns: {categorical_cols}')

# Auto-detect key fields based on column names
def find_col(keywords, default=None):
    col_lower = [c.lower() for c in df.columns]
    for kw in keywords:
        for i, c in enumerate(col_lower):
            if kw in c:
                return df.columns[i]
    return default

date_col = find_col(['date', 'month', 'year', 'time', 'period'])
region_col = find_col(['region', 'country', 'area', 'state', 'zone', 'branch'])
category_col = find_col(['category', 'product', 'type', 'segment', 'group'])
quantity_col = find_col(['quantity', 'qty', 'count', 'volume', 'unit'])
sales_col = find_col(['sales', 'revenue', 'amount', 'value', 'price', 'total', 'sum'])

print(f'[STATUS] Detected - date: {date_col}, region: {region_col}, category: {category_col}, qty: {quantity_col}, sales: {sales_col}')

# If sales_col not found, use first numeric column as measure
if sales_col is None and len(numeric_cols) > 0:
    sales_col = numeric_cols[0]
    print(f'[STATUS] Using first numeric column as measure: {sales_col}')

# ---- Step 2: Create Visualizations ----

plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette('husl')
plt.rcParams['figure.dpi'] = 150
plt.rcParams['savefig.dpi'] = 150

charts_created = []

# ====== Chart 1: Sales Performance Over Time (if date column exists) ======
if date_col:
    try:
        # Try to parse dates
        temp_date = pd.to_datetime(df[date_col], errors='coerce')
        if temp_date.notna().sum() > 5:
            df_plot = df.copy()
            df_plot['_date_parsed'] = temp_date
            df_plot = df_plot.dropna(subset=['_date_parsed']).sort_values('_date_parsed')
            
            # Aggregate by date period (monthly)
            df_plot['_period'] = df_plot['_date_parsed'].dt.to_period('M').astype(str)
            if sales_col:
                ts_data = df_plot.groupby('_period')[sales_col].sum().reset_index()
            elif quantity_col:
                ts_data = df_plot.groupby('_period')[quantity_col].sum().reset_index()
            else:
                # Use count as measure
                ts_data = df_plot.groupby('_period').size().reset_index(name='count')
                sales_col_for_ts = 'count'
            
            meas_col = sales_col if sales_col in ts_data.columns else (quantity_col if quantity_col in ts_data.columns else 'count')
            
            fig, ax = plt.subplots(figsize=(12, 6))
            ax.plot(ts_data['_period'], ts_data[meas_col], 
                    marker='o', linewidth=2, color='#2b6cb0', markersize=6)
            
            # Annotate key points (top 3)
            top3 = ts_data.nlargest(3, meas_col)
            for _, row in top3.iterrows():
                ax.annotate(f'{row[meas_col]:,.0f}',
                            xy=(row['_period'], row[meas_col]),
                            xytext=(0, 10), textcoords="offset points",
                            ha='center', fontsize=9, color='#2b6cb0',
                            fontweight='bold')
            
            ax.set_title('Sales Performance Over Time', fontsize=16, fontweight='bold', pad=15)
            ax.set_xlabel('Period', fontsize=12)
            ax.set_ylabel(meas_col.replace('_', ' ').title(), fontsize=12)
            ax.tick_params(axis='x', rotation=45)
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
            
            # Add trend line (simple moving average)
            if len(ts_data) >= 3:
                ts_data['_ma'] = ts_data[meas_col].rolling(window=3, min_periods=1).mean()
                ax.plot(ts_data['_period'], ts_data['_ma'], 
                        linestyle='--', linewidth=1.5, color='#e53e3e', alpha=0.7, label='3-period MA')
                ax.legend(fontsize=10)
            
            plt.tight_layout()
            chart_path = os.path.join(CHART_DIR, 'sales_trend.png')
            plt.savefig(chart_path, dpi=150, bbox_inches='tight')
            plt.close()
            charts_created.append({'name': 'sales_trend.png', 'type': 'line', 'purpose': 'Sales trend over time with moving average', 'audience': 'Executives'})
            print(f'[STATUS] Chart saved: {chart_path}')
    except Exception as e:
        print(f'[WARN] Could not create time series chart: {e}')

# ====== Chart 2: Regional Breakdown ======
if region_col and sales_col:
    try:
        region_data = df.groupby(region_col)[sales_col].sum().sort_values(ascending=False).reset_index()
        
        fig, ax = plt.subplots(figsize=(10, 6))
        
        # Use horizontal bar if too many categories
        if len(region_data) > 5:
            bars = ax.barh(region_data[region_col], region_data[sales_col], 
                          color=sns.color_palette('Blues_r', len(region_data)))
            ax.set_xlabel('Total ' + sales_col.replace('_', ' ').title(), fontsize=12)
            ax.set_ylabel(region_col.replace('_', ' ').title(), fontsize=12)
            
            # Annotate bars
            for bar in bars:
                width = bar.get_width()
                ax.annotate(f'{width:,.0f}',
                            xy=(width, bar.get_y() + bar.get_height() / 2),
                            xytext=(5, 0), textcoords="offset points",
                            ha='left', va='center', fontsize=9)
            ax.invert_yaxis()  # Highest on top
        else:
            bars = ax.bar(region_data[region_col], region_data[sales_col],
                         color=sns.color_palette('husl', len(region_data)))
            ax.set_xlabel(region_col.replace('_', ' ').title(), fontsize=12)
            ax.set_ylabel('Total ' + sales_col.replace('_', ' ').title(), fontsize=12)
            
            # Annotate bars
            for bar in bars:
                height = bar.get_height()
                ax.annotate(f'{height:,.0f}',
                            xy=(bar.get_x() + bar.get_width() / 2, height),
                            xytext=(0, 5), textcoords="offset points",
                            ha='center', va='bottom', fontsize=9)
        
        ax.set_title(f'{sales_col.replace("_", " ").title()} by {region_col.replace("_", " ").title()}', 
                    fontsize=16, fontweight='bold', pad=15)
        ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
        ax.tick_params(axis='x', rotation=45 if len(region_data) <= 5 else 0)
        
        plt.tight_layout()
        chart_path = os.path.join(CHART_DIR, 'regional_breakdown.png')
        plt.savefig(chart_path, dpi=150, bbox_inches='tight')
        plt.close()
        charts_created.append({'name': 'regional_breakdown.png', 'type': 'bar' if len(region_data) <= 5 else 'horizontal_bar', 
                              'purpose': f'{sales_col.title()} breakdown by {region_col}', 'audience': 'Regional Managers'})
        print(f'[STATUS] Chart saved: {chart_path}')
    except Exception as e:
        print(f'[WARN] Could not create regional chart: {e}')

# ====== Chart 3: Product Categories ======
if category_col and sales_col:
    try:
        cat_data = df.groupby(category_col)[sales_col].sum().sort_values(ascending=False).reset_index()
        
        # Pie if ≤ 5 categories, Treemap-like horizontal bar if more
        if len(cat_data) <= 5:
            fig, ax = plt.subplots(figsize=(8, 8))
            colors = sns.color_palette('husl', len(cat_data))
            wedges, texts, autotexts = ax.pie(
                cat_data[sales_col], 
                labels=cat_data[category_col],
                autopct='%1.1f%%',
                startangle=90,
                colors=colors,
                textprops={'fontsize': 11}
            )
            for autotext in autotexts:
                autotext.set_fontweight('bold')
            ax.set_title(f'{sales_col.replace("_", " ").title()} by {category_col.replace("_", " ").title()}', 
                        fontsize=16, fontweight='bold', pad=15)
        else:
            # Horizontal bar sorted highest to lowest
            fig, ax = plt.subplots(figsize=(10, max(5, len(cat_data) * 0.4)))
            colors = sns.color_palette('husl', len(cat_data))
            bars = ax.barh(cat_data[category_col], cat_data[sales_col], color=colors)
            
            # Annotate with value and percentage
            total = cat_data[sales_col].sum()
            for i, bar in enumerate(bars):
                width = bar.get_width()
                pct = (width / total) * 100
                ax.annotate(f'{width:,.0f} ({pct:.1f}%)',
                            xy=(width, bar.get_y() + bar.get_height() / 2),
                            xytext=(5, 0), textcoords="offset points",
                            ha='left', va='center', fontsize=9)
            
            ax.set_title(f'{sales_col.replace("_", " ").title()} by {category_col.replace("_", " ").title()}', 
                        fontsize=16, fontweight='bold', pad=15)
            ax.set_xlabel('Total ' + sales_col.replace('_', ' ').title(), fontsize=12)
            ax.invert_yaxis()
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
        
        plt.tight_layout()
        chart_path = os.path.join(CHART_DIR, 'product_categories.png')
        plt.savefig(chart_path, dpi=150, bbox_inches='tight')
        plt.close()
        chart_type = 'pie' if len(cat_data) <= 5 else 'horizontal_bar'
        charts_created.append({'name': 'product_categories.png', 'type': chart_type, 
                              'purpose': f'{sales_col.title()} distribution by {category_col}', 'audience': 'Product Managers'})
        print(f'[STATUS] Chart saved: {chart_path}')
    except Exception as e:
        print(f'[WARN] Could not create category chart: {e}')

# ====== Chart 4: Correlation Heatmap (if enough numeric columns) ======
if len(numeric_cols) >= 3:
    try:
        corr_matrix = df[numeric_cols].corr()
        
        fig, ax = plt.subplots(figsize=(10, 8))
        mask = np.triu(np.ones_like(corr_matrix, dtype=bool), k=1)
        sns.heatmap(corr_matrix, mask=mask, annot=True, fmt='.2f', 
                    cmap='coolwarm', center=0, square=True,
                    linewidths=0.5, cbar_kws={'shrink': 0.8})
        ax.set_title('Correlation Matrix', fontsize=16, fontweight='bold', pad=15)
        ax.tick_params(axis='x', rotation=45)
        ax.tick_params(axis='y', rotation=0)
        
        plt.tight_layout()
        chart_path = os.path.join(CHART_DIR, 'correlation_heatmap.png')
        plt.savefig(chart_path, dpi=150, bbox_inches='tight')
        plt.close()
        charts_created.append({'name': 'correlation_heatmap.png', 'type': 'heatmap', 
                              'purpose': 'Relationships between numeric variables', 'audience': 'Analysts'})
        print(f'[STATUS] Chart saved: {chart_path}')
    except Exception as e:
        print(f'[WARN] Could not create heatmap: {e}')

# ====== Chart 5: Top/Bottom Analysis ======
if sales_col:
    try:
        cat_for_top = category_col if category_col else (region_col if region_col else None)
        if cat_for_top:
            top_data = df.groupby(cat_for_top)[sales_col].sum().sort_values(ascending=False)
            top_n = min(10, len(top_data))
            top_df = top_data.head(top_n).reset_index()
            bottom_df = top_data.tail(min(5, len(top_data))).reset_index()
            
            # Top N bar chart
            fig, ax = plt.subplots(figsize=(10, 6))
            colors = ['#2b6cb0'] * len(top_df)
            bars = ax.bar(range(len(top_df)), top_df[sales_col], color=colors)
            
            # Highlight top 3
            for i in range(min(3, len(bars))):
                bars[i].set_color('#e53e3e')
            
            ax.set_xticks(range(len(top_df)))
            ax.set_xticklabels(top_df[cat_for_top], rotation=45, ha='right')
            ax.set_title(f'Top {top_n} {cat_for_top.replace("_", " ").title()} by {sales_col.replace("_", " ").title()}', 
                        fontsize=16, fontweight='bold', pad=15)
            ax.set_ylabel(sales_col.replace('_', ' ').title(), fontsize=12)
            ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
            
            # Annotate
            for bar in bars:
                height = bar.get_height()
                ax.annotate(f'{height:,.0f}',
                            xy=(bar.get_x() + bar.get_width() / 2, height),
                            xytext=(0, 5), textcoords="offset points",
                            ha='center', va='bottom', fontsize=8)
            
            plt.tight_layout()
            chart_path = os.path.join(CHART_DIR, 'top_performers.png')
            plt.savefig(chart_path, dpi=150, bbox_inches='tight')
            plt.close()
            charts_created.append({'name': 'top_performers.png', 'type': 'bar', 
                                  'purpose': f'Top {top_n} {cat_for_top} by {sales_col}', 'audience': 'Executives'})
            print(f'[STATUS] Chart saved: {chart_path}')
            
            # Summary statistics
            total_sales = df[sales_col].sum()
            top3_total = top_df.head(3)[sales_col].sum()
            top3_pct = (top3_total / total_sales) * 100 if total_sales > 0 else 0
            
    except Exception as e:
        print(f'[WARN] Could not create top analysis: {e}')

# ====== Chart 6: Distribution Analysis (if numeric columns exist) ======
if len(numeric_cols) >= 1:
    try:
        # Choose best numeric column (prefer sales/quantity)
        dist_col = sales_col if sales_col and sales_col in numeric_cols else numeric_cols[0]
        
        fig, axes = plt.subplots(1, 2, figsize=(14, 5))
        
        # Histogram + KDE
        sns.histplot(df[dist_col].dropna(), kde=True, ax=axes[0], color='#2b6cb0', bins=20)
        axes[0].set_title(f'Distribution of {dist_col.replace("_", " ").title()}', fontsize=14, fontweight='bold')
        axes[0].set_xlabel(dist_col.replace('_', ' ').title(), fontsize=11)
        axes[0].set_ylabel('Frequency', fontsize=11)
        axes[0].xaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
        
        # Box plot
        sns.boxplot(data=df, y=dist_col, ax=axes[1], color='#2b6cb0', width=0.4)
        axes[1].set_title(f'Box Plot of {dist_col.replace("_", " ").title()}', fontsize=14, fontweight='bold')
        axes[1].set_ylabel(dist_col.replace('_', ' ').title(), fontsize=11)
        axes[1].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{x:,.0f}'))
        
        # Add statistics text
        stats_text = f'Mean: {df[dist_col].mean():,.0f}\nMedian: {df[dist_col].median():,.0f}\nStd: {df[dist_col].std():,.0f}'
        axes[0].text(0.95, 0.95, stats_text, transform=axes[0].transAxes, 
                    fontsize=10, verticalalignment='top', horizontalalignment='right',
                    bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.5))
        
        plt.tight_layout()
        chart_path = os.path.join(CHART_DIR, 'distribution_analysis.png')
        plt.savefig(chart_path, dpi=150, bbox_inches='tight')
        plt.close()
        charts_created.append({'name': 'distribution_analysis.png', 'type': 'histogram_boxplot', 
                              'purpose': f'Distribution and outlier detection for {dist_col}', 'audience': 'Analysts'})
        print(f'[STATUS] Chart saved: {chart_path}')
    except Exception as e:
        print(f'[WARN] Could not create distribution chart: {e}')

# ---- Step 3: Save cleaned/enriched data ----
df_output = df.copy()
output_csv = os.path.join(OUTPUT_DIR, 'vera_output.csv')
df_output.to_csv(output_csv, index=False)
print(f'[STATUS] Saved output CSV: {output_csv}')

# ---- Step 4: Generate Vera Report ----
report_path = os.path.join(OUTPUT_DIR, 'vera_report.md')
with open(report_path, 'w', encoding='utf-8') as f:
    f.write('# Vera Visualization Report\n')
    f.write('=' * 50 + '\n\n')
    
    f.write('## Overview\n\n')
    f.write(f'- Input dataset: {df.shape[0]} rows × {df.shape[1]} columns\n')
    f.write(f'- Numeric columns: {len(numeric_cols)}\n')
    f.write(f'- Categorical columns: {len(categorical_cols)}\n')
    f.write(f'- Charts created: {len(charts_created)}\n\n')
    
    f.write('## Dataset Summary\n\n')
    f.write(f'| Column | Type | Non-null | Unique |\n')
    f.write(f'|--------|------|----------|--------|\n')
    for col in df.columns:
        dtype = str(df[col].dtype)
        non_null = df[col].notna().sum()
        unique = df[col].nunique()
        f.write(f'| {col} | {dtype} | {non_null} | {unique} |\n')
    f.write('\n')
    
    if sales_col:
        f.write(f'**Total {sales_col.replace("_", " ").title()}:** {df[sales_col].sum():,.0f}\n')
        f.write(f'**Average {sales_col.replace("_", " ").title()}:** {df[sales_col].mean():,.2f}\n')
        if top3_pct:
            f.write(f'**Top 3 concentration:** {top3_pct:.1f}% of total\n')
        f.write('\n')
    
    f.write('## Visuals Created\n\n')
    
    for i, chart in enumerate(charts_created, 1):
        f.write(f'### {i}. {chart["name"]}\n')
        f.write(f'- **Type:** {chart["type"]}\n')
        f.write(f'- **Purpose:** {chart["purpose"]}\n')
        f.write(f'- **Audience:** {chart["audience"]}\n')
        f.write(f'- **File:** `charts/{chart["name"]}`\n')
        f.write('\n')
    
    # Determine key visual
    if charts_created:
        key_visual = charts_created[0]  # First is usually sales trend
        for c in charts_created:
            if 'regional' in c['name']:
                key_visual = c
                break
            if 'performer' in c['name'] or 'top' in c['name']:
                key_visual = c
                break
        f.write(f'## Key Visual\n\n')
        f.write(f'**{key_visual["name"]}** — {key_visual["purpose"]}\n\n')
        f.write('This visual is most impactful because it directly addresses the core business question and provides actionable insights for decision-makers.\n\n')
    
    f.write('## Self-Improvement Report\n')
    f.write('=' * 50 + '\n')
    f.write('\n### Pre-Work Check\n')
    f.write('- Knowledge Base read: Yes\n')
    f.write('- Matplotlib style: seaborn-v0_8-whitegrid\n')
    f.write('- Color palette: husl (categorical), Blues_r (sequential), coolwarm (diverging)\n')
    
    f.write('\n### Methods Used\n')
    f.write('- Multi-chart approach covering key perspectives (trend, regional, category, correlation, distribution)\n')
    f.write('- Pie chart for ≤5 categories, horizontal bar for >5 categories\n')
    f.write('- Moving average overlay on time series\n')
    f.write('- Top-N analysis with highlight coloring\n')
    f.write('- Combined histogram + box plot for distribution analysis\n')
    
    f.write('\n### New Techniques Found\n')
    f.write('- Auto-detection of key columns based on keyword matching (date, region, category, sales)\n')
    f.write('- Fallback to first numeric column as measure if no sales column detected\n')
    f.write('- Statistics annotation box on distribution charts\n')
    
    f.write('\n### Will Apply Next Time\n')
    f.write('- Yes: Auto column detection + multi-faceted chart creation\n')
    
    f.write('\n### Knowledge Base Update\n')
    f.write('- Updated: Added auto-detection logic for common business columns\n')
    f.write('- Added: Combined histogram + box plot pattern for distribution analysis\n')
    f.write('- Added: Top-N concentration percentage calculation\n')

print(f'[STATUS] Report saved: {report_path}')
print(f'[STATUS] All charts created: {len(charts_created)} files in {CHART_DIR}')
print(f'[STATUS] Vera task completed successfully!')
