            # CV
            cv = StratifiedKFold(n_splits=3, shuffle=True, random_state=42)
            cv_scores = cross_val_score(model, X_train, y_train, cv=cv, scoring='f1_weighted')
            
            # Metrics
            acc = accuracy_score(y_test, y_pred)
            prec = precision_score(y_test, y_pred, average='weighted', zero_division=0)
            rec = recall_score(y_test, y_pred, average='weighted', zero_division=0)
            f1 = f1_score(y_test, y_pred, average='weighted', zero_division=0)
            
            if len(np.unique(y)) == 2:
                auc = roc_auc_score(y_test, y_proba)
            else:
                auc = roc_auc_score(y_test, y_proba, multi_class='ovr', average='weighted')
            
            results.append({
                'Model': name, 
                'Accuracy': round(acc, 4), 
                'Precision': round(prec, 4), 
                'Recall': round(rec, 4), 
                'F1_Weighted': round(f1, 4),
                'AUC': round(auc, 4),
                'CV_F1_mean': round(cv_scores.mean(), 4),
                'CV_F1_std': round(cv_scores.std(), 4)
            })
            predictions[name] = y_pred
            print(f'[STATUS] {name} - F1: {f1:.4f}, AUC: {auc:.4f}, CV: {cv_scores.mean():.4f}±{cv_scores.std():.4f}')
        except Exception as e:
            print(f'[WARN] {name} failed: {str(e)[:80]}')
            results.append({'Model': name, 'Accuracy': 0, 'Precision': 0, 'Recall': 0, 'F1_Weighted': 0, 'AUC': 0, 'CV_F1_mean': 0, 'CV_F1_std': 0})

elif target_reg:
    # Regression
    model_defs = []
    model_defs.append(('Linear Regression', LinearRegression()))
    model_defs.append(('Ridge', Ridge(alpha=1.0, random_state=42)))
    model_defs.append(('Lasso', Lasso(alpha=0.01, random_state=42)))
    model_defs.append(('Decision Tree', DecisionTreeRegressor(random_state=42)))
    model_defs.append(('Random Forest', RandomForestRegressor(n_estimators=100, random_state=42)))
    if HAVE_XGB:
        model_defs.append(('XGBoost', XGBRegressor(n_estimators=100, learning_rate=0.1, random_state=42)))
    if HAVE_LGBM:
        model_defs.append(('LightGBM', LGBMRegressor(n_estimators=100, learning_rate=0.1, random_state=42, verbose=-1)))
    
    for name, model in model_defs:
        try:
            if name in ['Linear Regression', 'Ridge', 'Lasso']:
                model.fit(X_train_scaled, y_train)
                y_pred = model.predict(X_test_scaled)
            else:
                model.fit(X_train, y_train)
                y_pred = model.predict(X_test)
            
            # CV
            cv = KFold(n_splits=3, shuffle=True, random_state=42)
            cv_scores = cross_val_score(model, X_train, y_train, cv=cv, scoring='neg_mean_squared_error')
            
            mse = mean_squared_error(y_test, y_pred)
            rmse = np.sqrt(mse)
            mae = mean_absolute_error(y_test, y_pred)
            r2 = r2_score(y_test, y_pred)
            
            results.append({
                'Model': name, 
                'RMSE': round(rmse, 4), 
                'MAE': round(mae, 4), 
                'R2': round(r2, 4),
                'CV_RMSE_mean': round(np.sqrt(-cv_scores.mean()), 4),
                'CV_RMSE_std': round(np.sqrt(cv_scores.std()), 4)
            })
            predictions[name] = y_pred
            print(f'[STATUS] {name} - RMSE: {rmse:.4f}, R2: {r2:.4f}')
        except Exception as e:
            print(f'[WARN] {name} failed: {str(e)[:80]}')
            results.append({'Model': name, 'RMSE': 99999, 'MAE': 99999, 'R2': -999, 'CV_RMSE_mean': 99999, 'CV_RMSE_std': 0})

# === [5] Results Comparison ===
results_df = pd.DataFrame(results)
if target_cls:
    results_df = results_df.sort_values('F1_Weighted', ascending=False)
elif target_reg:
    results_df = results_df.sort_values('RMSE', ascending=True)

print(f'\n[STATUS] Results:\n{results_df.to_string(index=False)}')

# === [6] Best Model & Feature Importance ===
if target_cls:
    best_name = results_df.iloc[0]['Model']
    best_f1 = results_df.iloc[0]['F1_Weighted']
    
    # Get best model for feature importance
    if best_name == 'Logistic Regression':
        best_model = LogisticRegression(max_iter=1000, random_state=42, class_weight='balanced').fit(X_train_scaled, y_train)
        if hasattr(best_model, 'coef_'):
            feat_imp = pd.DataFrame({'feature': X_cols, 'importance': np.abs(best_model.coef_[0])}).sort_values('importance', ascending=False)
        else:
            feat_imp = pd.DataFrame({'feature': X_cols, 'importance': 0})
    elif best_name == 'Decision Tree':
        best_model = DecisionTreeClassifier(random_state=42).fit(X_train, y_train)
        if hasattr(best_model, 'feature_importances_'):
            feat_imp = pd.DataFrame({'feature': X_cols, 'importance': best_model.feature_importances_}).sort_values('importance', ascending=False)
        else:
            feat_imp = pd.DataFrame({'feature': X_cols, 'importance': 0})
    elif best_name == 'Random Forest':
        best_model = RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced').fit(X_train, y_train)
        feat_imp = pd.DataFrame({'feature': X_cols, 'importance': best_model.feature_importances_}).sort_values('importance', ascending=False)
    elif best_name == 'XGBoost' and HAVE_XGB:
        best_model = XGBClassifier(n_estimators=100, learning_rate=0.1, random_state=42, eval_metric='logloss', use_label_encoder=False).fit(X_train, y_train)
        feat_imp = pd.DataFrame({'feature': X_cols, 'importance': best_model.feature_importances_}).sort_values('importance', ascending=False)
    elif best_name == 'LightGBM' and HAVE_LGBM:
        best_model = LGBMClassifier(n_estimators=100, learning_rate=0.1, random_state=42, class_weight='balanced', verbose=-1).fit(X_train, y_train)
        feat_imp = pd.DataFrame({'feature': X_cols, 'importance': best_model.feature_importances_}).sort_values('importance', ascending=False)
    else:
        feat_imp = pd.DataFrame({'feature': X_cols, 'importance': 0})
    
    overfit_check = 'ผ่าน' if abs(results_df.iloc[0]['Accuracy'] - results_df.iloc[0]['CV_F1_mean']) < 0.15 else 'ต้องระวัง'
