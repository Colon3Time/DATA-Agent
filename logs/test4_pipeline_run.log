import argparse
import os
import pandas as pd
from pathlib import Path
from datetime import datetime

parser = argparse.ArgumentParser()
parser.add_argument('--input',      default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# ── 1. Load data ─────────────────────────────────────────────
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape} rows × {len(df.columns)} cols")
print(f"[STATUS] Columns: {list(df.columns)}")

# ── 2. Detect numeric vs text columns ────────────────────────
num_cols = df.select_dtypes(include=['float64','int64','float32','int32']).columns.tolist()
object_cols = df.select_dtypes(include=['object']).columns.tolist()
# Also check string dtype
str_cols = df.select_dtypes(include=['string']).columns.tolist()
text_cols = object_cols + str_cols
print(f"[STATUS] Numeric: {num_cols}")
print(f"[STATUS] Text: {text_cols}")

# ── 3. Column insight detection ──────────────────────────────
# Check if this is a model comparison table from Mo
is_model_comparison = any(
    any(m in c.lower() for m in ['accuracy','f1','precision','recall','roc','auc','score','kendall','spearman','mae','mse','rmse','r2'])
    for c in df.columns
)
print(f"[STATUS] Is model comparison: {is_model_comparison}")

# If model comparison → extract key metrics only (skip template rows)
if is_model_comparison:
    # Try to find a "Model" or "Name" column
    model_col = None
    for c in df.columns:
        if 'model' in c.lower() or 'name' in c.lower() or 'classifier' in c.lower() or c.lower().startswith('unname') or c.lower().startswith('index'):
            model_col = c
            break
    if model_col is None:
        # Try first object column
        for c in text_cols:
            model_col = c
            break
    if model_col is None:
        model_col = df.columns[0]
    
    # Remove NaN/empty rows
    df_clean = df.dropna(how='all').copy()
    
    # Remove rows that are pure template (e.g., "---", empty strings, or headers like "Precision")
    df_clean = df_clean[~df_clean[model_col].astype(str).str.match(r'^[\s\-_]+$|^$', na=False)]
    
    # Try to convert metric columns to numeric
    for c in num_cols:
        if c in df_clean.columns:
            df_clean[c] = pd.to_numeric(df_clean[c], errors='coerce')
    
    # Also convert any remaining string columns that look numeric
    for c in text_cols:
        if c == model_col:
            continue
        if c in df_clean.columns:
            try:
                df_clean[c] = pd.to_numeric(df_clean[c], errors='coerce')
                if c not in num_cols:
                    num_cols.append(c)
            except:
                pass
    
    print(f"[STATUS] Cleaned rows: {df_clean.shape}, models: {df_clean[model_col].tolist()}")
    
    # ── 4. Generate business insights ───────────────────────────
    # Find best model by accuracy (or first available metric)
    metric_keywords = ['accuracy','f1','precision','recall','roc','auc','score','kendall','spearman','mae','mse','rmse','r2']
    metric_cols = [c for c in df_clean.columns if any(m in c.lower() for m in metric_keywords) and c in num_cols]
    print(f"[STATUS] Metric columns found: {metric_cols}")
    
    if not metric_cols:
        metric_cols = num_cols[:2]  # fallback to first 2 numeric cols
    
    insights = []
    
    # Find the best model
    if metric_cols:
        for mc in metric_cols:
            if mc not in df_clean.columns:
                continue
            # Sort by metric (descending for higher-is-better, ascending for error metrics)
            is_error_metric = any(m in mc.lower() for m in ['mae','mse','rmse'])
            ascending = is_error_metric
            df_sorted = df_clean.sort_values(mc, ascending=ascending, na_position='last')
            
            top_model = df_sorted[model_col].iloc[0] if len(df_sorted) > 0 else "N/A"
            top_value = df_sorted[mc].iloc[0] if len(df_sorted) > 0 else "N/A"
            
            # Handle NaN in top_value
            try:
                top_val_display = f"{float(top_value):.4f}" if pd.notna(top_value) else "N/A"
            except:
                top_val_display = str(top_value)
            
            # Get model count
            model_count = len(df_clean)
            
            insight_text = f"Best model by {mc}: {top_model} ({top_val_display})"
            impact_text = f"Top performer out of {model_count} models tested"
            insights.append((insight_text, impact_text, mc, top_model, top_value))
            print(f"[INSIGHT] {insight_text} → {impact_text}")
            break  # Use first metric only for simplicity
    
    # Check if any model dominates across multiple metrics
    if len(metric_cols) > 1 and len(insights) > 0:
        winning_models = {}
        for mc in metric_cols:
            if mc not in df_clean.columns:
                continue
            is_error_metric = any(m in mc.lower() for m in ['mae','mse','rmse'])
            ascending = is_error_metric
            df_sorted = df_clean.sort_values(mc, ascending=ascending, na_position='last')
            if len(df_sorted) > 0:
                winner = df_sorted[model_col].iloc[0]
                winning_models[winner] = winning_models.get(winner, 0) + 1
        
        if winning_models:
            dominant_model = max(winning_models, key=winning_models.get)
            if winning_models[dominant_model] > 1:
                insights.append((
                    f"{dominant_model} dominates {winning_models[dominant_model]}/{len(metric_cols)} metrics",
                    f"Consistent top performer across multiple evaluation dimensions → reliable choice for production"
                ))
                print(f"[INSIGHT] {insights[-1][0]} → {insights[-1][1]}")
    
    # Check for performance gaps
    if metric_cols:
        mc = metric_cols[0]
        if mc in df_clean.columns and len(df_clean) > 1:
            is_error_metric = any(m in mc.lower() for m in ['mae','mse','rmse'])
            ascending = is_error_metric
            df_sorted = df_clean.sort_values(mc, ascending=ascending, na_position='last')
            if len(df_sorted) >= 2:
                try:
                    top_val = float(df_sorted[mc].iloc[0])
                    second_val = float(df_sorted[mc].iloc[1])
                    if pd.notna(top_val) and pd.notna(second_val) and second_val != 0:
                        gap_pct = abs((top_val - second_val) / second_val) * 100
                        if gap_pct < 5:
                            insights.append((
                                f"Performance gap between top-2 models is only {gap_pct:.1f}%",
                                f"Consider secondary factors (latency, cost, interpretability) for final model selection"
                            ))
                            print(f"[INSIGHT] {insights[-1][0]} → {insights[-1][1]}")
                except:
                    pass
    
    # ── 5. Save filtered data ──────────────────────────────────
    filtered_path = os.path.join(OUTPUT_DIR, 'iris_output.csv')
    df_clean.to_csv(filtered_path, index=False)
    print(f"[STATUS] Saved: {filtered_path}")
    
    # ── 6. Write insights.md ────────────────────────────────────
    insights_md = f"""Iris Chief Insight Report
==========================

## Business Context
- **Source**: Model comparison output from Mo agent
- **Models evaluated**: {len(df_clean)} models
- **Metrics analyzed**: {', '.join(metric_cols) if metric_cols else 'N/A'}

## Top Insights
"""
    for i, ins in enumerate(insights, 1):
        if len(ins) >= 4:
            insights_md += f"### {i}. {ins[0]}\n- **Business Impact**: {ins[1]}\n- **Action**: {'Deploy ' + str(ins[3]) + ' as primary model' if i == 1 else 'Consider secondary factors for final decision'}\n\n"
        else:
            insights_md += f"### {i}. {ins[0]}\n- **Business Impact**: {ins[1]}\n- **Action**: {'Consider deployment' if i == 1 else 'Evaluate trade-offs'}\n\n"
    
    # Add summary by model if multiple models
    if len(df_clean) > 1:
        insights_md += "## Model Performance Summary\n\n"
        insights_md += f"| {model_col} | " + " | ".join(metric_cols) + " |\n"
        insights_md += "|---" + "|---" * len(metric_cols) + "|\n"
        for _, row in df_clean.iterrows():
            model_name = row[model_col]
            vals = []
            for mc in metric_cols:
                try:
                    v = float(row[mc]) if pd.notna(row[mc]) else "N/A"
                    vals.append(f"{v:.4f}" if isinstance(v, float) else str(v))
                except:
                    vals.append(str(row.get(mc, "N/A")))
            insights_md += f"| {model_name} | " + " | ".join(vals) + " |\n"
        insights_md += "\n"
    
    # Priority Recommendations
    insights_md += """## Priority Recommendations

- **High**: Deploy the best-performing model based on primary business metric
- **Medium**: Validate with A/B testing on a small user segment before full rollout
- **Low**: Monitor model drift and retrain periodically with new data

## Trend Alert
- No specific industry trend detected from model comparison data alone
- Recommend cross-referencing with customer data for business context

"""
    
    insights_path = os.path.join(OUTPUT_DIR, 'insights.md')
    with open(insights_path, 'w', encoding='utf-8') as f:
        f.write(insights_md)
    print(f"[STATUS] Saved: {insights_path}")
    
    # ── 7. Write recommendations.md ─────────────────────────────
    recommendations_md = f"""Iris Business Recommendations
===============================

## Priority Matrix

### High Priority (must do immediately)
1. **Deploy Top Model**
   - Model: {insights[0][3] if insights else 'N/A'}
   - Metric: {insights[0][2] if insights else 'N/A'} = {insights[0][4] if insights and len(insights[0]) > 4 else 'N/A'}
   - Timeline: 1-2 weeks

### Medium Priority (should do soon)
1. **A/B Testing**
   - Validate top model performance on real data
   - Monitor key business KPIs during testing
   - Timeline: 2-4 weeks

### Low Priority (future consideration)
1. **Monitor & Retrain**
   - Set up model monitoring for drift detection
   - Schedule regular retraining cycles
   - Timeline: Quarterly

## Expected Business Impact
- Improved prediction accuracy → better decision making
- Reduced manual effort → cost savings
- Scalable model deployment → growth enablement

---
*Generated by Iris — Chief Insight Officer*
"""
    
    rec_path = os.path.join(OUTPUT_DIR, 'recommendations.md')
    with open(rec_path, 'w', encoding='utf-8') as f:
        f.write(recommendations_md)
    print(f"[STATUS] Saved: {rec_path}")

else:
    # Generic case - not a model comparison
    print("[STATUS] Input does not appear to be a model comparison. Using generic insight generation.")
    
    # Simple stats
    insights_md = f"""Iris Chief Insight Report
==========================

## Business Context
- **Source**: {os.path.basename(INPUT_PATH)}
- **Rows**: {len(df)}
- **Columns**: {len(df.columns)}

## Data Overview
| Column | Type | Unique Values | Missing |
|--------|------|---------------|---------|
"""
    for c in df.columns:
        dtype = str(df[c].dtype)
        uniq = df[c].nunique()
        missing = df[c].isna().sum()
        insights_md += f"| {c} | {dtype} | {uniq} | {missing} |\n"
    
    insights_md += "\n## Recommendations\n- Further analysis needed to generate business insights from this data\n"
    
    insights_path = os.path.join(OUTPUT_DIR, 'insights.md')
    with open(insights_path, 'w', encoding='utf-8') as f:
        f.write(insights_md)
    print(f"[STATUS] Saved: {insights_path}")
    
    # Generic recommendations
    rec_md = """## Recommendations
1. Explore data quality and completeness
2. Identify key patterns and trends
3. Generate actionable business insights
"""
    rec_path = os.path.join(OUTPUT_DIR, 'recommendations.md')
    with open(rec_path, 'w', encoding='utf-8') as f:
        f.write(rec_md)
    print(f"[STATUS] Saved: {rec_path}")

# ── 8. Self-Improvement Report ────────────────────────────────
self_improvement = f"""Self-Improvement Report
=======================
Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M')}
Method used: Column insight detection + content filtering
