print(f'[STATUS] OUTPUT_DIR = {OUTPUT_DIR}')
print(f'[STATUS] CHARTS_DIR = {CHARTS_DIR}')

# ============================================================
# Load Data
# ============================================================
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/*.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f'[STATUS] Found CSV from MD parent: {INPUT_PATH}')

if not os.path.exists(INPUT_PATH):
    print(f'[ERROR] Input file not found: {INPUT_PATH}')
    sys.exit(1)

df = pd.read_csv(INPUT_PATH)
