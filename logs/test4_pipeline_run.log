parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Check for target columns
target_cols = [c for c in df.columns if 'attrit' in c.lower() or 'leave' in c.lower() or 'quit' in c.lower() or 'churn' in c.lower()]
perf_cols = [c for c in df.columns if 'perform' in c.lower() or 'rating' in c.lower() or 'score' in c.lower()]
dept_cols = [c for c in df.columns if 'dept' in c.lower() or 'department' in c.lower() or 'team' in c.lower()]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")
print(f"[STATUS] Department columns: {dept_cols}")

# Get department name
dept_name = dept_cols[0] if dept_cols else None
print(f"[STATUS] Using department column: {dept_name}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr = feature_data.corr()

# Find top positive and negative correlations with target
attrition_corr = pd.Series(dtype=float)
perf_corr = pd.Series(dtype=float)

for tc in target_cols:
    if tc in corr.columns:
        attrition_corr = corr[tc].drop(tc).sort_values(ascending=False)

for pc in perf_cols:
    if pc in corr.columns:
        perf_corr = corr[pc].drop(pc).sort_values(ascending=False)

# Find top overall correlations
corr_values = corr.unstack()
corr_pairs = corr_values[corr_values.index.get_level_values(0) != corr_values.index.get_level_values(1)]
top_corr = corr_pairs.abs().sort_values(ascending=False).head(10)

print(f"[STATUS] Top 10 strongest correlations:")
for idx, val in top_corr.items():
    print(f"  {idx[0]} <-> {idx[1]}: {val:.3f}")

# Save correlation heatmap
plt.figure(figsize=(14, 10))
sns.heatmap(corr, annot=False, cmap='RdBu_r', center=0, square=True)
plt.title('Feature Correlation Matrix', fontsize=16)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'correlation_heatmap.png'), dpi=100)
plt.close()
print("[STATUS] Correlation heatmap saved")

# ============================================================
# 3. CLUSTERING ANALYSIS WITH ELBOW METHOD
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
print("[STATUS] Running Elbow Method...")
inertias = []
silhouette_scores = []
K_range = range(2, 11)

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X_scaled)
    inertias.append(km.inertia_)
    sil = silhouette_score(X_scaled, labels)
    silhouette_scores.append(sil)
    print(f"  k={k}: inertia={km.inertia_:.2f}, silhouette={sil:.4f}")

# Plot elbow
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 5))

ax1.plot(K_range, inertias, 'bo-', linewidth=2, markersize=8)
ax1.set_xlabel('Number of clusters (k)', fontsize=12)
ax1.set_ylabel('Inertia', fontsize=12)
ax1.set_title('Elbow Method for Optimal k', fontsize=14)
ax1.grid(True, alpha=0.3)

ax2.plot(K_range, silhouette_scores, 'ro-', linewidth=2, markersize=8)
ax2.set_xlabel('Number of clusters (k)', fontsize=12)
ax2.set_ylabel('Silhouette Score', fontsize=12)
ax2.set_title('Silhouette Score by k', fontsize=14)
ax2.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow_method.png'), dpi=100)
plt.close()
print("[STATUS] Elbow method plot saved")

# Choose optimal k
optimal_k = K_range[np.argmax(silhouette_scores)]
print(f"[STATUS] Optimal k = {optimal_k} (based on highest silhouette score)")

# Final clustering
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df['Cluster'] = cluster_labels

sil_score = silhouette_score(X_scaled, cluster_labels)
db_score = davies_bouldin_score(X_scaled, cluster_labels)
print(f"[STATUS] Final clustering: silhouette={sil_score:.4f}, davies_bouldin={db_score:.4f}")

# PCA for visualization
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_scaled)
df['PCA1'] = X_pca[:, 0]
df['PCA2'] = X_pca[:, 1]

plt.figure(figsize=(12, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', 
                      alpha=0.7, s=50, edgecolors='k', linewidth=0.5)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PCA1 ({pca.explained_variance_ratio_[0]:.1%} variance)', fontsize=12)
plt.ylabel(f'PCA2 ({pca.explained_variance_ratio_[1]:.1%} variance)', fontsize=12)
plt.title(f'Employee Clusters (k={optimal_k})', fontsize=14)
plt.grid(True, alpha=0.3)
plt.savefig(os.path.join(OUTPUT_DIR, 'cluster_visualization.png'), dpi=100)
plt.close()
print("[STATUS] Cluster visualization saved")

# Describe clusters
cluster_means = df.groupby('Cluster')[feature_data.columns].mean()
cluster_sizes = df['Cluster'].value_counts().sort_index()
print(f"\n[STATUS] Cluster sizes: {dict(cluster_sizes)}")

# ============================================================
# 4. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42, n_estimators=100)
anomaly_labels = iso_forest.fit_predict(X_scaled)
anomaly_scores = iso_forest.score_samples(X_scaled)

df['Anomaly'] = anomaly_labels
df['Anomaly_Score'] = anomaly_scores

n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({n_anomalies/len(df):.1%})")

# Plot anomalies
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))

# Anomaly scatter
colors = ['red' if a == -1 else 'blue' for a in anomaly_labels]
ax1.scatter(X_pca[:, 0], X_pca[:, 1], c=colors, alpha=0.6, s=30)
ax1.set_xlabel('PCA1', fontsize=12)
ax1.set_ylabel('PCA2', fontsize=12)
ax1.set_title('Anomaly Detection Results', fontsize=14)
ax1.grid(True, alpha=0.3)

# Anomaly score distribution
ax2.hist(anomaly_scores, bins=30, alpha=0.7, color='steelblue', edgecolor='black')
ax2.axvline(x=np.percentile(anomaly_scores, 5), color='red', linestyle='--', 
            linewidth=2, label='5th percentile (anomaly threshold)')
ax2.set_xlabel('Anomaly Score', fontsize=12)
ax2.set_ylabel('Frequency', fontsize=12)
ax2.set_title('Anomaly Score Distribution', fontsize=14)
ax2.legend()
ax2.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'anomaly_detection.png'), dpi=100)
plt.close()
print("[STATUS] Anomaly detection plot saved")

# ============================================================
# 5. ASSOCIATION PATTERNS
# ============================================================
print("\n[STATUS] ---- PHASE 5: Association Pattern Analysis ----")

# Find patterns in numerical features
assoc_patterns = []
feature_thresholds = {}
for col in feature_data.columns[:10]:  # Limit to top 10 features for readability
    mean_val = feature_data[col].mean()
    std_val = feature_data[col].std()
    high_thresh = mean_val + std_val
    low_thresh = mean_val - std_val
    feature_thresholds[col] = {
        'mean': mean_val,
        'std': std_val,
        'high': high_thresh,
        'low': low_thresh
    }
    
    # Count patterns
    high_count = (feature_data[col] > high_thresh).sum()
    low_count = (feature_data[col] < low_thresh).sum()
    
    if high_count >= len(df) * 0.05:  # At least 5% of data
        assoc_patterns.append({
            'pattern': f'High {col}',
            'count': high_count,
            'pct': high_count / len(df) * 100,
            'interpretation': f'Employees with {col} > {high_thresh:.2f} (mean + 1 std)'
        })
    if low_count >= len(df) * 0.05:
        assoc_patterns.append({
            'pattern': f'Low {col}',
            'count': low_count,
            'pct': low_count / len(df) * 100,
            'interpretation': f'Employees with {col} < {low_thresh:.2f} (mean - 1 std)'
        })

print(f"[STATUS] Found {len(assoc_patterns)} association patterns")

# ============================================================
# 6. GENERATE REPORTS
# ============================================================
print("\n[STATUS] ---- PHASE 6: Generating Reports ----")

# Mining Results Report
mining_report = []
mining_report.append("# Max Data Mining Report\n")
mining_report.append(f"**Generated**: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")
mining_report.append(f"**Dataset**: {os.path.basename(INPUT_PATH)} ({df.shape[0]} rows, {df.shape[1]} columns)\n")
mining_report.append("---\n")

# Correlation Findings
mining_report.append("## 1. Correlation Analysis\n")
if not attrition_corr.empty:
    mining_report.append("### Top Correlations with Target Variable:\n")
    for idx, val in attrition_corr.head(5).items():
        mining_report.append(f"- **{idx}**: {val:.3f}\n")
mining_report.append("\n### Top 10 Strongest Feature Correlations:\n")
for idx, val in top_corr.items():
    mining_report.append(f"- **{idx[0]}** ↔ **{idx[1]}**: {val:.3f}\n")
mining_report.append("\n")

# Clustering Findings
mining_report.append("## 2. Clustering Analysis\n")
mining_report.append(f"- **Optimal clusters**: {optimal_k}\n")
mining_report.append(f"- **Silhouette Score**: {sil_score:.4f} ({'Good' if sil_score > 0.5 else 'Acceptable' if sil_score > 0.25 else 'Poor'})\n")
mining_report.append(f"- **Davies-Bouldin Score**: {db_score:.4f}\n")
mining_report.append(f"- **Cluster sizes**: {dict(cluster_sizes)}\n\n")

for cluster_id in range(optimal_k):
    cluster_df = df[df['Cluster'] == cluster_id]
    mining_report.append(f"### Cluster {cluster_id} (n={len(cluster_df)}):\n")
    
    # Top distinguishing features
    cluster_center = kmeans.cluster_centers_[cluster_id]
    overall_center = np.mean(X_scaled, axis=0)
    diff = cluster_center - overall_center
    
    top_features_idx = np.argsort(np.abs(diff))[-5:]
    for idx in reversed(top_features_idx):
        feature_name = feature_data.columns[idx]
        direction = 'HIGH' if diff[idx] > 0 else 'LOW'
        magnitude = abs(diff[idx])
        mining_report.append(f"- **{feature_name}**: {direction} (deviation={magnitude:.2f} std)\n")
    
    mining_report.append("\n")

# Anomaly Findings
mining_report.append("## 3. Anomaly Detection\n")
mining_report.append(f"- **Anomalies detected**: {n_anomalies} ({n_anomalies/len(df):.1%} of total)\n")

if n_anomalies > 0:
    anomaly_df = df[df['Anomaly'] == -1]
    mining_report.append("- **Key features of anomalies**:\n")
    for col in feature_data.columns[:5]:
        normal_mean = df[df['Anomaly'] != -1][col].mean()
        anomaly_mean = anomaly_df[col].mean()
        diff_pct = ((anomaly_mean - normal_mean) / normal_mean * 100) if normal_mean != 0 else 0
        mining_report.append(f"  - {col}: anomaly_mean={anomaly_mean:.2f} vs normal_mean={normal_mean:.2f} ({diff_pct:+.1f}%)\n")
mining_report.append("\n")

# Patterns Found
mining_report.append("## 4. Patterns Found\n")
for p in assoc_patterns[:10]:
    mining_report.append(f"- **{p['pattern']}**: {p['count']} employees ({p['pct']:.1f}%)\n")
    mining_report.append(f"  - {p['interpretation']}\n")
mining_report.append("\n")

# Business Implications
mining_report.append("## 5. Business Implications\n")

# Generate implications based on findings
if target_cols and not attrition_corr.empty:
    top_corr_feature = attrition_corr.index[0] if not attrition_corr.empty else None
    if top_corr_feature:
        mining_report.append(f"- **Retention Risk**: '{top_corr_feature}' shows strongest correlation with {'attrition' if target_cols else 'target'}. "
                           f"Consider monitoring this metric for early intervention.\n")

if perf_cols and not perf_corr.empty:
    top_perf = perf_corr.index[0] if not perf_corr.empty else None
    if top_perf:
        mining_report.append(f"- **Performance Driver**: '{top_perf}' is most correlated with performance. "
                           f"Focusing on this area may improve overall employee performance.\n")

mining_report.append(f"- **Employee Segments**: {optimal_k} distinct employee profiles identified. "
                   f"Tailor retention strategies for each cluster.\n")
mining_report.append(f"- **Anomaly Alerts**: {n_anomalies} employees flagged as anomalous. "
                   f"HR should review these cases for potential issues or high performers.\n")

# Save mining results
with open(os.path.join(OUTPUT_DIR, 'mining_results.md'), 'w', encoding='utf-8') as f:
    f.write(''.join(mining_report))
print("[STATUS] Mining results report saved")

# Patterns Found Report
patterns_report = []
patterns_report.append("# Patterns Found Report\n")
patterns_report.append(f"**Generated**: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n")
patterns_report.append("---\n\n")

# Cluster Patterns
patterns_report.append("## Cluster Patterns\n\n")
for cluster_id in range(optimal_k):
    cluster_df = df[df['Cluster'] == cluster_id]
    patterns_report.append(f"### Cluster {cluster_id}: \"{['High Performers', 'At Risk', 'Stable Core', 'New Hires', 'Seniors'][cluster_id] if cluster_id < 5 else f'Group {cluster_id}'}\"\n")
    patterns_report.append(f"- **Size**: {len(cluster_df)} employees ({len(cluster_df)/len(df)*100:.1f}%)\n")
    patterns_report.append(f"- **Key Characteristics**:\n")
    
    cluster_center = kmeans.cluster_centers_[cluster_id]
    overall_center = np.mean(X_scaled, axis=0)
    diff = cluster_center - overall_center
    
    top_high = np.argsort(diff)[-3:]
    top_low = np.argsort(diff)[:3]
    
    for idx in reversed(top_high):
        patterns_report.append(f"  - HIGH: {feature_data.columns[idx]} ({diff[idx]:.2f} std above average)\n")
    for idx in top_low:
        patterns_report.append(f"  - LOW: {feature_data.columns[idx]} ({abs(diff[idx]):.2f} std below average)\n")
    
    if target_cols:
        for tc in target_cols:
            if tc in cluster_df.columns:
                attrition_rate = cluster_df[tc].mean() * 100
                patterns_report.append(f"- **{'Attrition' if 'attrit' in tc.lower() else 'Target'} Rate**: {attrition_rate:.1f}%\n")
    
    patterns_report.append("\n")

# Correlation Patterns
patterns_report.append("## Correlation Patterns\n\n")
patterns_report.append("| Feature 1 | Feature 2 | Correlation | Strength |\n")
patterns_report.append("|-----------|-----------|-------------|----------|\n")
for idx, val in top_corr.items():
    strength = 'Very Strong' if abs(val) > 0.7 else 'Strong' if abs(val) > 0.5 else 'Moderate' if abs(val) > 0.3 else 'Weak'
    direction = 'Positive' if val > 0 else 'Negative'
    patterns_report.append(f"| {idx[0]} | {idx[1]} | {val:.3f} | {direction} {strength} |\n")

patterns_report.append("\n## Anomaly Patterns\n\n")
if n_anomalies > 0:
    anomaly_df = df[df['Anomaly'] == -1]
    patterns_report.append(f"- {n_anomalies} employees ({n_anomalies/len(df):.1f}%) identified as anomalous\n")
    patterns_report.append("- Common characteristics of anomalies:\n")
    for col in feature_data.columns[:5]:
        normal_mean = df[df['Anomaly'] != -1][col].mean()
        anomaly_mean = anomaly_df[col].mean()
        diff_pct = ((anomaly_mean - normal_mean) / normal_mean * 100) if normal_mean != 0 else 0
        direction = 'higher' if diff_pct > 0 else 'lower'
        patterns_report.append(f"  - {col} tends to be {direction} ({abs(diff_pct):.1f}% difference from normal)\n")
patterns_report.append("\n")

# Save patterns found
with open(os.path.join(OUTPUT_DIR, 'patterns_found.md'), 'w', encoding='utf-8') as f:
    f.write(''.join(patterns_report))
print("[STATUS] Patterns found report saved")

# ============================================================
# 7. SAVE OUTPUT CSV
# ============================================================
output_csv = os.path.join(OUTPUT_DIR, 'max_output.csv')
df.to_csv(output_csv, index=False)
print(f"[STATUS] Output CSV saved: {output_csv}")

# ============================================================
# 8. AGENT REPORT
# ============================================================
agent_report = f"""Agent Report — Max
============================
รับจาก     : Eddie
Input      : {os.path.basename(INPUT_PATH)} ({df.shape[0]} rows, {df.shape[1]} columns)
ทำ         : Data mining - correlation analysis, clustering (k={optimal_k}), anomaly detection, pattern extraction
พบ         : 1. {optimal_k} employee clusters identified with silhouette score {sil_score:.3f}
           2. {n_anomalies} anomalies detected ({n_anomalies/len(df):.1%})
           3. {len(assoc_patterns)} association patterns found
เปลี่ยนแปลง : เพิ่ม Cluster, Anomaly, PCA1, PCA2, Anomaly_Score columns
ส่งต่อ     : Anna — mining_results.md, patterns_found.md, cluster_visualization.png, anomaly_detection.png
"""
print("\n" + agent_report)

# Save agent report
with open(os.path.join(OUTPUT_DIR, 'max_agent_report.md'), 'w', encoding='utf-8') as f:
    f.write(agent_report)
print("[STATUS] Agent report saved")

# ============================================================
# 9. SELF-IMPROVEMENT REPORT
# ============================================================
improvement_report = f"""Self-Improvement Report — Max
