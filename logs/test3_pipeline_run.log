args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Load data
df = pd.read_csv(INPUT_PATH)
print(f'[STATUS] Loaded: {df.shape}')
print(f'[STATUS] Columns: {list(df.columns)}')
print(f'[STATUS] Dtypes:\n{df.dtypes}')

# Explore data
print(f'\n[STATUS] First 3 rows:\n{df.head(3).to_string()}')
print(f'\n[STATUS] Basic stats:\n{df.describe(include="all").to_string()}')

# Check for nulls
null_summary = df.isnull().sum()
null_cols = null_summary[null_summary > 0]
if len(null_cols) > 0:
    print(f'\n[STATUS] Columns with nulls:\n{null_cols}')
else:
    print('\n[STATUS] No null values found')

# Detect structure
expected_cols = ['question', 'answer_raw', 'answer_cleaned', 'score', 'status', 'notes']
found_cols = [c for c in expected_cols if c in df.columns]
print(f'\n[STATUS] Found expected columns: {found_cols}')

# Summary statistics
total_questions = len(df)
print(f'\n[STATUS] Total questions: {total_questions}')

# Score analysis if score column exists
if 'score' in df.columns:
    df['score'] = pd.to_numeric(df['score'], errors='coerce')
    avg_score = df['score'].mean()
    min_score = df['score'].min()
    max_score = df['score'].max()
    score_bins = [0, 0.25, 0.5, 0.75, 0.9, 1.01]
    score_labels = ['0-25% (Poor)', '25-50% (Below Avg)', '50-75% (Average)', '75-90% (Good)', '90-100% (Excellent)']
    df['score_band'] = pd.cut(df['score'], bins=score_bins, labels=score_labels, right=False)
    score_dist = df['score_band'].value_counts().sort_index()
    print(f'\n[STATUS] Avg score: {avg_score:.3f}')
    print(f'[STATUS] Min score: {min_score:.3f}')
    print(f'[STATUS] Max score: {max_score:.3f}')
    print(f'[STATUS] Score distribution:\n{score_dist}')

# Status analysis if status column exists
if 'status' in df.columns:
    status_dist = df['status'].value_counts()
    print(f'\n[STATUS] Status distribution:\n{status_dist}')

# Find low-scoring questions (below 0.5) for recommendations
low_score_questions = []
if 'score' in df.columns:
    low_score = df[df['score'] < 0.5]
    print(f'\n[STATUS] Low scoring questions (< 0.5): {len(low_score)}')
    if len(low_score) > 0 and 'question' in low_score.columns:
        for _, row in low_score.iterrows():
            q_text = row["question"][:80] if isinstance(row["question"], str) else str(row["question"])
            print(f'  - "{q_text}..." → score={row["score"]:.3f}')
            low_score_questions.append({'question': q_text, 'score': row["score"]})

# Topic/category analysis
topic_col = None
for col in ['topic', 'category', 'domain', 'type']:
    if col in df.columns:
        topic_dist = df[col].value_counts()
        print(f'\n[STATUS] {col} distribution:\n{topic_dist}')
        topic_col = col
        break

# ===== Generate Final Report =====
lines = []
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
lines.append("  Executive Summary")
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

if 'score' in df.columns:
    lines.append(f"Quality Control analysis completed on **{len(df)} questions**.")
    lines.append(f"Average score: **{avg_score:.1%}** (Range: {min_score:.1%} - {max_score:.1%}).")
    pct_poor = (len(df[df['score'] < 0.5]) / len(df)) * 100
    pct_good = (len(df[df['score'] >= 0.75]) / len(df)) * 100
    lines.append(f"{pct_good:.0f}% of answers scored \"Good\" or better (≥0.75), while {pct_poor:.0f}% require improvement (<0.5).")
else:
    lines.append(f"Quality Control analysis completed on **{len(df)} questions**.")

lines.append("")

# Key Findings
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
lines.append("  Key Findings")
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

if 'score' in df.columns:
    # Finding 1: Overall quality
    lines.append("① **Overall Quality: {}**".format("Good" if avg_score >= 0.75 else ("Average" if avg_score >= 0.5 else "Needs Improvement")))
    lines.append(f"   Average score of {avg_score:.1%} indicates {'strong' if avg_score >= 0.75 else 'moderate' if avg_score >= 0.5 else 'poor'} answer quality across the dataset.")

    # Finding 2: Score distribution
    dist_text = ", ".join([f"**{label}**: {count} ({count/total_questions*100:.0f}%)" for label, count in zip(score_labels, [score_dist.get(l, 0) for l in score_labels])])
    lines.append("② **Score Distribution:**")
    lines.append(f"   {dist_text}")

    # Finding 3: Low performers
    if len(low_score_questions) > 0:
        lines.append("③ **Low Performers Identified:**")
        lines.append(f"   {len(low_score_questions)} question{'s' if len(low_score_questions) > 1 else ''} scored below 0.5 requiring immediate review.")
        for item in low_score_questions[:5]:
            lines.append(f"   - \"{item['question']}...\" (score={item['score']:.2f})")
        if len(low_score_questions) > 5:
            lines.append(f"   ... and {len(low_score_questions) - 5} more.")

# Status findings
if 'status' in df.columns:
    lines.append("")
    lines.append(f"④ **Status Breakdown:**")
    for status, count in status_dist.items():
        lines.append(f"   - {status}: {count} ({count/total_questions*100:.0f}%)")

lines.append("")

# Recommendations
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
lines.append("  Recommendations")
lines.append("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

if 'score' in df.columns:
    # High priority
    if len(low_score_questions) > 0:
        lines.append("🔴 **High:** Review and fix {} low-scoring questions immediately".format(len(low_score_questions)))
        lines.append("   → Re-run QC with corrected answers to improve overall score.")
    elif avg_score < 0.5:
        lines.append("🔴 **High:** Overall quality is below threshold. Full review needed.")
    else:
        lines.append("🟢 **Low:** No critical issues found. Proceed to next stage.")

    # Medium priority
    if avg_score < 0.75:
        missing = total_questions - len(df[df['score'] >= 0.75])
        lines.append("🟡 **Medium:** {} questions scored below 0.75 — consider iterative improvement.".format(missing))
    else:
        lines.append("🟢 **Low:** Score quality meets threshold (≥75%). No medium priority items.")

# Final low priority
lines.append("🟢 **Low:** Maintain current standards and continue monitoring.")

lines.append("")
lines.append("---")
lines.append(f"_Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}_")

final_report_text = "\n".join(lines)

# Save final report
report_path = os.path.join(OUTPUT_DIR, 'final_report.md')
with open(report_path, 'w', encoding='utf-8') as f:
    f.write(final_report_text)
print(f'[STATUS] Saved: {report_path}')

# ===== Executive Summary (1 page) =====
exec_lines = []
exec_lines.append("# Executive Summary — QC Report")
exec_lines.append("")
exec_lines.append(f"**Dataset:** {len(df)} questions evaluated")
if 'score' in df.columns:
    exec_lines.append(f"**Overall Score:** {avg_score:.1%}")
    exec_lines.append(f"**Range:** {min_score:.1%} — {max_score:.1%}")
exec_lines.append("")
