import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Check for target columns
target_cols = [c for c in df.columns if 'attrit' in c.lower() or 'leave' in c.lower() or 'quit' in c.lower() or 'churn' in c.lower()]
perf_cols = [c for c in df.columns if 'perform' in c.lower() or 'rating' in c.lower() or 'score' in c.lower()]
dept_cols = [c for c in df.columns if 'dept' in c.lower() or 'department' in c.lower() or 'team' in c.lower()]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")
print(f"[STATUS] Department columns: {dept_cols}")

# Get department name
dept_name = dept_cols[0] if dept_cols else None
print(f"[STATUS] Using department column: {dept_name}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr = feature_data.corr()

# Find top positive and negative correlations with target
attrition_corr = pd.Series(dtype=float)
target_col = target_cols[0] if target_cols else None

if target_col and target_col in feature_data.columns:
    attrition_corr = feature_data.corrwith(feature_data[target_col]).drop(target_col).abs().sort_values(ascending=False)
    print(f"[STATUS] Top 10 features correlated with {target_col}:")
    for feat, score_val in attrition_corr.head(10).items():
        print(f"  {feat}: {score_val:.3f}")

# ============================================================
# 3. CLUSTERING ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
print("[STATUS] Running Elbow Method...")
inertias = []
silhouettes = []
K_range = range(2, 11)

for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    labels = km.fit_predict(X_scaled)
    inertias.append(km.inertia_)
    sil = silhouette_score(X_scaled, labels) if len(set(labels)) > 1 else 0
    silhouettes.append(sil)

# Plot elbow
plt.figure(figsize=(12, 5))
plt.subplot(1, 2, 1)
plt.plot(K_range, inertias, 'bo-')
plt.xlabel('Number of clusters')
plt.ylabel('Inertia')
plt.title('Elbow Method')
plt.grid(True, alpha=0.3)

plt.subplot(1, 2, 2)
plt.plot(K_range, silhouettes, 'ro-')
plt.xlabel('Number of clusters')
plt.ylabel('Silhouette Score')
plt.title('Silhouette Score Analysis')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow.png'), dpi=150)
plt.close()
print("[STATUS] Elbow plot saved")

# Find optimal k
optimal_k = K_range[np.argmax(silhouettes)]
print(f"[STATUS] Optimal K (silhouette): {optimal_k}")

# Run final clustering
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df['Cluster'] = cluster_labels

sil_score = silhouette_score(X_scaled, cluster_labels)
db_score = davies_bouldin_score(X_scaled, cluster_labels)
print(f"[STATUS] Silhouette Score: {sil_score:.3f}")
print(f"[STATUS] Davies-Bouldin Score: {db_score:.3f}")

# Analyze clusters
print("[STATUS] Analyzing clusters...")
cluster_profiles = []
for k in range(optimal_k):
    cluster_data = df[df['Cluster'] == k]
    profile = {
        'cluster_id': k,
        'size': len(cluster_data),
        'percentage': len(cluster_data)/len(df)*100
    }
    # Get mean of numeric columns for this cluster
    numeric_means = cluster_data[numeric_cols].mean()
    for col, val in numeric_means.items():
        if col not in ['Cluster']:
            profile[f'{col}_mean'] = val
    cluster_profiles.append(profile)

cluster_df = pd.DataFrame(cluster_profiles)
print(f"[STATUS] Cluster profiles created: {len(cluster_profiles)} clusters")

# PCA for visualization
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_scaled)

plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.6, s=50)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} var)')
plt.ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} var)')
plt.title(f'Employee Clusters (K-Means, k={optimal_k})')
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig(os.path.join(OUTPUT_DIR, 'clusters_pca.png'), dpi=150)
plt.close()
print("[STATUS] PCA cluster visualization saved")

# ============================================================
# 4. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42, n_estimators=100)
anomaly_labels = iso_forest.fit_predict(X_scaled)
anomaly_scores = iso_forest.decision_function(X_scaled)

df['Anomaly'] = anomaly_labels
df['Anomaly_Score'] = anomaly_scores

n_anomalies = sum(anomaly_labels == -1)
print(f"[STATUS] Anomalies detected: {n_anomalies}/{len(df)} ({n_anomalies/len(df)*100:.1f}%)")

# Describe anomalies
anomalies_df = df[df['Anomaly'] == -1]
normal_df = df[df['Anomaly'] == 1]
anomaly_comparison = pd.DataFrame()
for col in numeric_cols:
    if col not in ['Cluster', 'Anomaly']:
        anomaly_comparison.loc['mean_normal', col] = normal_df[col].mean()
        anomaly_comparison.loc['mean_anomaly', col] = anomalies_df[col].mean()
        anomaly_comparison.loc['diff_pct', col] = ((anomalies_df[col].mean() - normal_df[col].mean()) / normal_df[col].mean() * 100)

print(f"[STATUS] Anomaly comparison: {anomaly_comparison.shape}")

# ============================================================
# 5. ASSOCIATION PATTERNS (for categorical data)
# ============================================================
print("\n[STATUS] ---- PHASE 5: Association Pattern Analysis ----")

# Find categorical columns for association
cat_cols = df.select_dtypes(include=['object', 'str']).columns.tolist()
print(f"[STATUS] Categorical columns for patterns: {cat_cols[:5]}")

patterns = []
if dept_name and perf_cols:
    # Cross-tab patterns
    for pcol in perf_cols[:3]:
        if pcol in df.columns:
            ct = pd.crosstab(df[dept_name], df[pcol] if pcol in df.columns else pd.Series([0]*len(df)))
            # Find strong associations
            chi2_val = 0
            if ct.size > 0:
                try:
                    from scipy.stats import chi2_contingency
                    chi2_val, p_val, _, _ = chi2_contingency(ct.fillna(0))
                    if p_val < 0.05:
                        patterns.append({
                            'type': 'association',
                            'description': f"Significant association between {dept_name} and {pcol} (p={p_val:.4f})",
                            'strength': 'strong' if p_val < 0.01 else 'moderate'
                        })
                except:
                    pass

# Department-specific patterns if target exists
if target_col and dept_name:
    # Average attrition by department
    dept_attrition = df.groupby(dept_name)[target_col].mean() if target_col in df.columns else df.groupby(dept_name).size()
    if len(dept_attrition) > 1:
        highest_dept = dept_attrition.idxmax()
        highest_rate = dept_attrition.max()
        patterns.append({
            'type': 'segment',
            'description': f"Highest {target_col}: {highest_dept} ({highest_rate:.1%})",
            'strength': 'strong' if highest_rate > 0.3 else 'moderate'
        })

# Cluster patterns
for k in range(optimal_k):
    cluster_data = df[df['Cluster'] == k]
    pattern_desc = f"Cluster {k}: {len(cluster_data)} employees ({len(cluster_data)/len(df)*100:.1f}%)"
    if target_col and target_col in cluster_data.columns:
        target_rate = cluster_data[target_col].mean()
        pattern_desc += f", {target_col} rate: {target_rate:.1%}"
    patterns.append({
        'type': 'cluster',
        'description': pattern_desc,
        'strength': 'strong' if len(cluster_data) > len(df)/optimal_k*1.2 else 'moderate'
    })

# Anomaly patterns
if n_anomalies > 0:
    patterns.append({
        'type': 'anomaly',
