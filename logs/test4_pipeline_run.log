    ax.set_xlabel('Position', fontsize=12)
    ax.set_ylabel('Salary', fontsize=12)
    ax.set_title('Salary Distribution by Position', fontsize=14, fontweight='bold')
    ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'{x:,.0f}'))
    
    plt.tight_layout()
    chart2_path = os.path.join(CHARTS_DIR, 'salary_boxplot_by_position.png')
    plt.savefig(chart2_path, dpi=150, bbox_inches='tight')
    plt.close()
    print(f'[STATUS] Chart 2 saved: {chart2_path}')
    
    # Find outliers
    for pos in medians.index:
        pos_data = plot_df[plot_df[position_col] == pos][salary_col]
        q1 = pos_data.quantile(0.25)
        q3 = pos_data.quantile(0.75)
        iqr = q3 - q1
        outliers = pos_data[(pos_data < q1 - 1.5*iqr) | (pos_data > q3 + 1.5*iqr)]
        if len(outliers) > 0:
            print(f'[INSIGHT] Position "{pos}": {len(outliers)} salary outliers')
else:
