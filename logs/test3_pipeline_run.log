🔗 **Related Files:**
  - Raw Results: {INPUT_PATH}
  - CSV Output: {os.path.join(OUTPUT_DIR, 'rex_output.csv')}

📊 **Full Data Snapshot:**
```
  Questions processed: {total_questions}
  Avg score: {avg_score:.3f}
  Min score: {min_score:.3f}  |  Max score: {max_score:.3f}
  Std dev: {df['score'].std():.3f}
```
"""

# --- EXECUTIVE SUMMARY ---
exec_summary = f"""━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  Pipeline Quality — Executive Summary
  Project: 2026-04-25_test3 | Date: {datetime.now().strftime('%Y-%m-%d')}
