                'RMSE': round(rmse, 4),
                'MAE': round(mae, 4),
                'CV Mean': round(cv_mean, 4),
                'CV Std': round(cv_std, 4),
                'Time (s)': round(elapsed, 2)
            })
            
            if r2 > best_score:
                best_score = r2
                best_model = model
                best_name = name
                
        except Exception as e:
