print(f'[STATUS] Columns: {list(df.columns)}')
print(f'[STATUS] Data types:\n{df.dtypes}')

# ============================================================
# Data Preparation & Feature Engineering
# ============================================================
# Detect key columns based on common HR dataset patterns
all_cols = [c.lower().replace(' ', '_').replace('-', '_') for c in df.columns]
col_map = dict(zip([c.lower().replace(' ', '_').replace('-', '_') for c in df.columns], df.columns))

# Standardize column names
df_clean = df.copy()
df_clean.columns = [c.lower().replace(' ', '_').replace('-', '_') for c in df_clean.columns]

print(f'[STATUS] Standardized columns: {list(df_clean.columns)}')

# Identify key columns
def find_col(keywords, df_cols):
    for kw in keywords:
        for c in df_cols:
            if kw in c.lower():
                return c
    return None

dept_col = find_col(['department', 'dept', 'division', 'unit'], df_clean.columns)
position_col = find_col(['position', 'job', 'role', 'title', 'level'], df_clean.columns)
attrition_col = find_col(['attrition', 'left', 'churn', 'quit', 'turnover', 'status'], df_clean.columns)
salary_col = find_col(['salary', 'income', 'compensation', 'pay', 'wage'], df_clean.columns)
performance_col = find_col(['performance', 'rating', 'score', 'perf'], df_clean.columns)
satisfaction_col = find_col(['satisfaction', 'satis', 'engagement', 'happy'], df_clean.columns)
education_col = find_col(['education', 'edu', 'degree'], df_clean.columns)
age_col = find_col(['age'], df_clean.columns)
gender_col = find_col(['gender', 'sex'], df_clean.columns)
tenure_col = find_col(['tenure', 'experience', 'years_at_company', 'years_employed', 'service_years'], df_clean.columns)
overtime_col = find_col(['overtime', 'over_time', 'extra_hours'], df_clean.columns)

print(f'[STATUS] Detected: dept={dept_col}, position={position_col}, attrition={attrition_col}, salary={salary_col}, perf={performance_col}, satis={satisfaction_col}')

# If no explicit attrition column, check if any column has binary 0/1 pattern
if attrition_col is None:
    for c in df_clean.columns:
        if df_clean[c].dtype in ['int64', 'float64'] and df_clean[c].nunique() == 2:
            vals = set(df_clean[c].dropna().unique())
            if vals.issubset({0, 1}):
                attrition_col = c
                print(f'[STATUS] Inferred attrition from: {c}')
                break

# If no position column, try to find hierarchical position-like column
if position_col is None:
    for c in df_clean.columns:
        if df_clean[c].dtype == 'object' and df_clean[c].nunique() <= 20:
            if 'position' in c or 'job' in c or 'role' in c or 'title' in c:
                position_col = c
                break

print(f'[STATUS] Final - Attrition: {attrition_col}, Position: {position_col}')

# Set style
