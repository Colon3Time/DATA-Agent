import argparse
import os
import pandas as pd
import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.ensemble import IsolationForest
from sklearn.metrics import silhouette_score, davies_bouldin_score
from pathlib import Path
import json
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

parser = argparse.ArgumentParser()
parser.add_argument('--input', default='')
parser.add_argument('--output-dir', default='')
args, _ = parser.parse_known_args()

INPUT_PATH = args.input
OUTPUT_DIR = args.output_dir
os.makedirs(OUTPUT_DIR, exist_ok=True)

# Handle .md input — find CSV in parent
if INPUT_PATH.endswith('.md'):
    parent = Path(INPUT_PATH).parent.parent
    csvs = sorted(parent.glob('**/dana_output.csv')) + sorted(parent.glob('**/*_output.csv'))
    if csvs:
        INPUT_PATH = str(csvs[0])
        print(f"[STATUS] Resolved .md input → CSV: {INPUT_PATH}")

print("[STATUS] Loading employee data...")
df = pd.read_csv(INPUT_PATH)
print(f"[STATUS] Loaded: {df.shape}")
print(f"[STATUS] Columns: {list(df.columns)}")

# ============================================================
# 1. DATA PREPARATION
# ============================================================
print("\n[STATUS] ---- PHASE 1: Data Preparation ----")

# Identify key columns
target_cols = [c for c in df.columns if any(k in c.lower() for k in ['attrit', 'leave', 'quit', 'churn', 'target', 'label'])]
dept_cols = [c for c in df.columns if any(k in c.lower() for k in ['dept', 'department', 'team'])]
perf_cols = [c for c in df.columns if any(k in c.lower() for k in ['perform', 'rating', 'score', 'efficien'])]

print(f"[STATUS] Target columns found: {target_cols}")
print(f"[STATUS] Department columns: {dept_cols}")
print(f"[STATUS] Performance columns: {perf_cols}")

# Encode categorical columns
df_encoded = df.copy()
label_encoders = {}
for col in df_encoded.select_dtypes(include=['object', 'str']).columns:
    le = LabelEncoder()
    df_encoded[col] = le.fit_transform(df_encoded[col].astype(str))
    label_encoders[col] = le

# Separate features for clustering
exclude_cols = target_cols + ['employee_id', 'id', 'name', 'emp_id', 'employee', 'name_emp']
feature_cols = [c for c in df_encoded.columns if c not in exclude_cols]
if not feature_cols:
    feature_cols = df_encoded.columns.tolist()

# Handle NaN — only numeric columns
numeric_cols = df_encoded[feature_cols].select_dtypes(include=[np.number]).columns
df_encoded[numeric_cols] = df_encoded[numeric_cols].fillna(df_encoded[numeric_cols].median())
feature_data = df_encoded[numeric_cols]

print(f"[STATUS] Features for analysis: {list(feature_data.columns)}")
print(f"[STATUS] Numeric feature count: {len(numeric_cols)}")

# ============================================================
# 2. CORRELATION ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 2: Correlation Analysis ----")

corr = feature_data.corr()

# Find correlations with target if exists
attrition_corr = pd.Series(dtype=float)
if target_cols:
    target_col = target_cols[0]
    target_corr = corr[target_col].drop(target_col).sort_values(ascending=False)
    attrition_corr = target_corr
    print(f"[STATUS] Top 5 positive correlations with '{target_col}':")
    for col, val in target_corr.head(5).items():
        print(f"   {col}: {val:.4f}")
    print(f"[STATUS] Top 5 negative correlations with '{target_col}':")
    for col, val in target_corr.tail(5).items():
        print(f"   {col}: {val:.4f}")

# Save correlation heatmap
plt.figure(figsize=(14, 10))
sns.heatmap(corr, annot=False, cmap='coolwarm', center=0, linewidths=0.5)
plt.title('Feature Correlation Matrix', fontsize=14)
plt.tight_layout()
corr_path = os.path.join(OUTPUT_DIR, 'correlation_heatmap.png')
plt.savefig(corr_path, dpi=100)
plt.close()
print(f"[STATUS] Correlation heatmap saved: {corr_path}")

# ============================================================
# 3. CLUSTERING ANALYSIS
# ============================================================
print("\n[STATUS] ---- PHASE 3: Clustering Analysis ----")

# Scale features
scaler = StandardScaler()
X_scaled = scaler.fit_transform(feature_data)

# Elbow Method
inertias = []
K_range = range(2, 11)
for k in K_range:
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    km.fit(X_scaled)
    inertias.append(km.inertia_)

plt.figure(figsize=(8, 5))
plt.plot(K_range, inertias, 'bo-')
plt.xlabel('Number of clusters')
plt.ylabel('Inertia')
plt.title('Elbow Method for Optimal K')
plt.grid(True, alpha=0.3)
plt.savefig(os.path.join(OUTPUT_DIR, 'elbow.png'), dpi=100)
plt.close()
print("[STATUS] Elbow plot saved: elbow.png")

# Determine optimal K (find "elbow")
diffs = np.diff(inertias)
diffs2 = np.diff(diffs)
optimal_k = np.argmin(diffs2) + 2  # +2 because diffs2 starts at index 2
optimal_k = max(2, min(optimal_k, 8))
print(f"[STATUS] Optimal K determined: {optimal_k}")

# Run K-Means with optimal K
kmeans = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)
cluster_labels = kmeans.fit_predict(X_scaled)
df_encoded['Cluster'] = cluster_labels
df['Cluster'] = cluster_labels

# Cluster quality metrics
sil_score = silhouette_score(X_scaled, cluster_labels)
db_score = davies_bouldin_score(X_scaled, cluster_labels)
print(f"[STATUS] Silhouette Score: {sil_score:.4f} {'✓ Good' if sil_score > 0.5 else '⚠ Acceptable'}")
print(f"[STATUS] Davies-Bouldin Score: {db_score:.4f} {'✓ Good' if db_score < 1 else '⚠ Fair'}")

# PCA for visualization
pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_scaled)
df['PCA1'] = X_pca[:, 0]
df['PCA2'] = X_pca[:, 1]

plt.figure(figsize=(10, 8))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=cluster_labels, cmap='viridis', alpha=0.7, s=50)
plt.colorbar(scatter, label='Cluster')
plt.xlabel(f'PCA1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PCA2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title(f'K-Means Clusters (k={optimal_k})')
plt.grid(True, alpha=0.3)
plt.savefig(os.path.join(OUTPUT_DIR, 'cluster_pca.png'), dpi=100)
plt.close()
print("[STATUS] Cluster PCA visualization saved")

# Analyze clusters
cluster_summary = []
for i in range(optimal_k):
    cluster_data = df_encoded[df_encoded['Cluster'] == i]
    cluster_original = df[df['Cluster'] == i]
    
    # Numeric means (safe)
    numeric_means = cluster_data[numeric_cols].mean().to_dict() if len(cluster_data) > 0 else {}
    
    # Top features
    if numeric_means:
        top_features = sorted(numeric_means.items(), key=lambda x: abs(x[1]), reverse=True)[:5]
    else:
        top_features = []
    
    # Dept distribution if available
    dept_dist = {}
    if dept_cols:
        dept_name = dept_cols[0]
        if dept_name in df.columns:
            dept_dist = cluster_original[dept_name].value_counts().head(3).to_dict()
    
    # Target rate if available
    target_rate = 0
    if target_cols:
        target_col = target_cols[0]
        if target_col in df_encoded.columns:
            target_rate = cluster_data[target_col].mean()
    
    cluster_summary.append({
        'cluster': i,
        'size': len(cluster_data),
        'pct': len(cluster_data) / len(df) * 100,
        'top_features': top_features,
        'dept_distribution': dept_dist,
        'target_rate': target_rate
    })

# Print cluster summary
print("\n[STATUS] Cluster Summary:")
for cs in cluster_summary:
    print(f"\n  Cluster {cs['cluster']} ({cs['size']} employees, {cs['pct']:.1f}%):")
    print(f"    Top features: {cs['top_features'][:3]}")
    if cs['dept_distribution']:
        print(f"    Top departments: {dict(list(cs['dept_distribution'].items())[:3])}")
    if cs['target_rate'] > 0:
        print(f"    Target rate: {cs['target_rate']:.2%}")

# ============================================================
# 4. ANOMALY DETECTION
# ============================================================
print("\n[STATUS] ---- PHASE 4: Anomaly Detection ----")

iso_forest = IsolationForest(contamination=0.05, random_state=42, n_estimators=100)
anomaly_labels = iso_forest.fit_predict(X_scaled)
df['Anomaly'] = anomaly_labels

n_anomalies = (anomaly_labels == -1).sum()
print(f"[STATUS] Anomalies detected: {n_anomalies} ({n_anomalies/len(df)*100:.1f}%)")

# Characterize anomalies
anomaly_df = df[df['Anomaly'] == -1]
normal_df = df[df['Anomaly'] == 1]

anomaly_means = anomaly_df[numeric_cols].mean() if len(anomaly_df) > 0 else pd.Series(dtype=float)
normal_means = normal_df[numeric_cols].mean() if len(normal_df) > 0 else pd.Series(dtype=float)

anomaly_characteristics = {}
if len(anomaly_means) > 0 and len(normal_means) > 0:
    diff = (anomaly_means - normal_means).abs().sort_values(ascending=False)
    top_diff = diff.head(5)
    for col, val in top_diff.items():
        anomaly_characteristics[col] = {
            'anomaly_mean': float(anomaly_means[col]),
            'normal_mean': float(normal_means[col]),
            'diff': float(val)
        }
    print(f"[STATUS] Top differentiating features for anomalies:")
    for col, info in anomaly_characteristics.items():
        print(f"   {col}: anomaly={info['anomaly_mean']:.2f} vs normal={info['normal_mean']:.2f}")

# Save anomaly visualization
plt.figure(figsize=(10, 8))
colors = ['red' if a == -1 else 'blue' for a in anomaly_labels]
plt.scatter(X_pca[:, 0], X_pca[:, 1], c=colors, alpha=0.6, s=30)
plt.xlabel(f'PCA1 ({pca.explained_variance_ratio_[0]:.1%} variance)')
plt.ylabel(f'PCA2 ({pca.explained_variance_ratio_[1]:.1%} variance)')
plt.title(f'Anomaly Detection (Isolation Forest): {n_anomalies} anomalies')
plt.grid(True, alpha=0.3)
plt.savefig(os.path.join(OUTPUT_DIR, 'anomalies.png'), dpi=100)
plt.close()
print("[STATUS] Anomaly visualization saved")

# ============================================================
# 5. PATTERN DETECTION (Association-like patterns)
# ============================================================
print("\n[STATUS] ---- PHASE 5: Pattern Detection ----")

# Find patterns based on cluster + features
patterns = []
for cs in cluster_summary:
    cluster = cs['cluster']
    
    # Pattern based on target rate
    if cs['target_rate'] > 0:
        if cs['target_rate'] > 0.5:
            patterns.append({
                'pattern': f'Cluster {cluster}: High Target Group',
                'cluster': cluster,
                'confidence': float(cs['target_rate']),
                'size': cs['size'],
                'evidence': f'{cs["pct"]:.1f}% of employees, target rate {cs["target_rate"]:.1%}',
                'action': 'Needs immediate attention and intervention'
            })
        elif cs['target_rate'] > 0.3:
            patterns.append({
                'pattern': f'Cluster {cluster}: Moderate Risk Group',
                'cluster': cluster,
                'confidence': float(cs['target_rate']),
                'size': cs['size'],
                'evidence': f'{cs["pct"]:.1f}% of employees, target rate {cs["target_rate"]:.1%}',
                'action': 'Monitor and provide support programs'
            })
    
    # Pattern based on size
    if cs['pct'] > 30:
        patterns.append({
            'pattern': f'Cluster {cluster}: Major Employee Segment ({cs["pct"]:.1f}%)',
            'cluster': cluster,
            'confidence': cs['pct'] / 100,
            'size': cs['size'],
            'evidence': f'Largest cluster representing {cs["pct"]:.1f}% of workforce',
            'action': 'Focus retention strategies on this large segment'
        })
    
    # Pattern based on top features
    if cs['top_features']:
        key_feature = cs['top_features'][0]
        patterns.append({
            'pattern': f'Cluster {cluster} characterized by {key_feature[0] if isinstance(key_feature, tuple) else key_feature}',
            'cluster': cluster,
            'confidence': 0.7,
            'size': cs['size'],
            'evidence': f'{key_feature[0] if isinstance(key_feature, tuple) else key_feature} = {key_feature[1] if isinstance(key_feature, tuple) else "high"}',
            'action': 'Tailor programs to this segment\'s key characteristics'
        })

# Anomaly-based pattern
if n_anomalies > 5:
    patterns.append({
        'pattern': f'Anomalous Employee Group ({n_anomalies} employees)',
        'cluster': -1,
        'confidence': 0.6,
        'size': n_anomalies,
        'evidence': f'{n_anomalies/len(df)*100:.1f}% of workforce identified as outliers',
        'action': 'Review individual cases for retention risk or high performance'
    })

# Correlation-based patterns (if target exists)
if len(attrition_corr) > 0:
    top_pos = attrition_corr.head(3)
    top_neg = attrition_corr.tail(3)
    for col, val in top_pos.items():
        if abs(val) > 0.3:
            patterns.append({
                'pattern': f'Strong correlation: {col} positively associated with target ({val:.3f})',
                'cluster': -1,
                'confidence': float(abs(val)),
                'size': -1,
