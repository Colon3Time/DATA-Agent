    ax.set_title('Attrition Rate by Department', fontsize=14, fontweight='bold')
    ax.set_ylabel('Attrition Rate (%)', fontsize=11)
    ax.set_xlabel('Department', fontsize=11)
    plt.xticks(rotation=45, ha='right', fontsize=9)
    plt.tight_layout()
    plt.savefig(os.path.join(CHARTS_DIR, 'attrition_rate_by_dept.png'), dpi=150, bbox_inches='tight')
    plt.close()
    print('[STATUS] Chart 1: attrition_rate_by_dept.png saved')
else:
