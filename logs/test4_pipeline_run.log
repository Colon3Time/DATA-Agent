        z = np.polyfit(df[performance_col], df[satisfaction_col], 1)
        p = np.poly1d(z)
        x_line = np.linspace(df[performance_col].min(), df[performance_col].max(), 100)
        ax.plot(x_line, p(x_line), 'r--', alpha=0.7, linewidth=1.5, label='Trend')
        ax.legend(fontsize=9)
    except:
        pass
    
    ax.set_title('Performance vs Satisfaction Score', fontsize=14, fontweight='bold')
    ax.set_xlabel('Performance Score', fontsize=11)
    ax.set_ylabel('Satisfaction Score', fontsize=11)
