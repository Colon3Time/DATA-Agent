print('\n[STATUS] Creating Chart 1: Attrition Rate by Department')

if dept_col and attrition_col:
    attr_dept = df_clean.groupby(dept_col)[attrition_col].mean().reset_index()
    attr_dept.columns = [dept_col, 'attrition_rate']
    attr_dept = attr_dept.sort_values('attrition_rate', ascending=True)
    
    fig, ax = plt.subplots(figsize=(12, 6))
